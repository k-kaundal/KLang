# ===========================================
# Main Demo Function
# ===========================================

fn main() {
    # Clear screen for better presentation
    # print("\x1b[2J\x1b[H")
    
    # Print main banner
    println()
    println("\x1b[1m\x1b[36m" + "═══════════════════════════════════════════════════════════" + "\x1b[0m")
    println("\x1b[1m\x1b[36m" + "                  KLang CLI Library Demo                  " + "\x1b[0m")
    println("\x1b[1m\x1b[36m" + "           Beautiful Command-Line Interfaces               " + "\x1b[0m")
    println("\x1b[1m\x1b[36m" + "═══════════════════════════════════════════════════════════" + "\x1b[0m")
    
    # Run all demos
    demoColors()
    demoBoxes()
    demoProgressBars()
    demoTables()
    demoMenus()
    demoStatusMessages()
    demoLists()
    demoHeaders()
    demoIcons()
    demoComplexExample()
    
    # Footer
    println()
    println("\x1b[1m\x1b[36m" + "═══════════════════════════════════════════════════════════" + "\x1b[0m")
    println("\x1b[1m\x1b[36m" + "                    Demo Complete! 🚀                      " + "\x1b[0m")
    println("\x1b[1m\x1b[36m" + "═══════════════════════════════════════════════════════════" + "\x1b[0m")
    println()
}

# Run the demo
main()
