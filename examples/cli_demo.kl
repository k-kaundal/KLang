# ============================================
# KLang CLI Library Demo
# ============================================
# Demonstrates the beautiful CLI library features
# Shows colors, boxes, progress bars, tables, menus, and more

# Import the CLI library
# Note: In full implementation, this would be: import cli from "stdlib/cli"
# For now, we'll include the functionality inline or assume it's available

# ===========================================
# Demo 1: Colors and Text Formatting
# ===========================================

fn demoColors() {
    println()
    println("╔════════════════════════════════════════════════╗")
    println("║     Colors and Text Formatting Demo           ║")
    println("╚════════════════════════════════════════════════╝")
    println()
    
    # Basic colors
    println("\x1b[31m" + "Red text" + "\x1b[0m")
    println("\x1b[32m" + "Green text" + "\x1b[0m")
    println("\x1b[33m" + "Yellow text" + "\x1b[0m")
    println("\x1b[34m" + "Blue text" + "\x1b[0m")
    println("\x1b[35m" + "Magenta text" + "\x1b[0m")
    println("\x1b[36m" + "Cyan text" + "\x1b[0m")
    println()
    
    # Bright colors
    println("\x1b[91m" + "Bright Red" + "\x1b[0m")
    println("\x1b[92m" + "Bright Green" + "\x1b[0m")
    println("\x1b[93m" + "Bright Yellow" + "\x1b[0m")
    println("\x1b[94m" + "Bright Blue" + "\x1b[0m")
    println("\x1b[96m" + "Bright Cyan" + "\x1b[0m")
    println()
    
    # Text styles
    println("\x1b[1m" + "Bold text" + "\x1b[0m")
    println("\x1b[2m" + "Dim text" + "\x1b[0m")
    println("\x1b[3m" + "Italic text" + "\x1b[0m")
    println("\x1b[4m" + "Underlined text" + "\x1b[0m")
    println()
    
    # Combined styles
    println("\x1b[1m\x1b[32m" + "Bold Green" + "\x1b[0m")
    println("\x1b[1m\x1b[31m" + "Bold Red" + "\x1b[0m")
    println("\x1b[1m\x1b[33m" + "Bold Yellow" + "\x1b[0m")
    println()
}

# ===========================================
# Demo 2: Box Drawing
# ===========================================

fn demoBoxes() {
    println()
    println("╔════════════════════════════════════════════════╗")
    println("║           Box Drawing Demo                     ║")
    println("╚════════════════════════════════════════════════╝")
    println()
    
    # Single line box
    println("Single Line Box:")
    println("┌────────────────────────┐")
    println("│  KLang CLI Library     │")
    println("│  Beautiful Interfaces  │")
    println("└────────────────────────┘")
    println()
    
    # Double line box
    println("Double Line Box:")
    println("╔════════════════════════╗")
    println("║  KLang CLI Library     ║")
    println("║  Beautiful Interfaces  ║")
    println("╚════════════════════════╝")
    println()
    
    # Rounded box
    println("Rounded Box:")
    println("╭────────────────────────╮")
    println("│  KLang CLI Library     │")
    println("│  Beautiful Interfaces  │")
    println("╰────────────────────────╯")
    println()
    
    # Box with title
    println("Box with Title:")
    println("┌─────── Welcome ────────┐")
    println("│  KLang CLI Library     │")
    println("└────────────────────────┘")
    println()
}

# ===========================================
# Demo 3: Progress Bars
# ===========================================

fn demoProgressBars() {
    println()
    println("╔════════════════════════════════════════════════╗")
    println("║          Progress Bars Demo                    ║")
    println("╚════════════════════════════════════════════════╝")
    println()
    
    # Simple progress bar
    println("Simple Progress Bars:")
    println("[████████████████████░░░░░░░░░░░░░░░░░░░░] 50%")
    println("[████████████████████████████████████████] 100%")
    println()
    
    # Colored progress bars
    println("Colored Progress Bars:")
    println("\x1b[31m[████░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░]\x1b[0m \x1b[31m10%\x1b[0m")
    println("\x1b[33m[████████████████░░░░░░░░░░░░░░░░░░░░░░░░]\x1b[0m \x1b[33m40%\x1b[0m")
    println("\x1b[32m[████████████████████████████████████████]\x1b[0m \x1b[32m100%\x1b[0m")
    println()
    
    # Progress with different styles
    println("Different Progress Styles:")
    println("[▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓░░░░░░░░░░░░░░░░░░░░] 50%")
    println("[■■■■■■■■■■■■■■■■■■■■□□□□□□□□□□□□□□□□□□□□] 50%")
    println()
}

# ===========================================
# Demo 4: Tables
# ===========================================

fn demoTables() {
    println()
    println("╔════════════════════════════════════════════════╗")
    println("║             Tables Demo                        ║")
    println("╚════════════════════════════════════════════════╝")
    println()
    
    # Simple table
    println("User Information Table:")
    println("┌────────────┬──────────────────┬─────────┐")
    println("│ " + "\x1b[1m\x1b[36m" + "Name" + "\x1b[0m" + "       │ " + "\x1b[1m\x1b[36m" + "Email" + "\x1b[0m" + "            │ " + "\x1b[1m\x1b[36m" + "Role" + "\x1b[0m" + "    │")
    println("├────────────┼──────────────────┼─────────┤")
    println("│ Alice      │ alice@klang.dev  │ Admin   │")
    println("│ Bob        │ bob@klang.dev    │ User    │")
    println("│ Charlie    │ charlie@klang.dev│ User    │")
    println("└────────────┴──────────────────┴─────────┘")
    println()
    
    # Status table
    println("System Status Table:")
    println("┌────────────────┬──────────┬────────────┐")
    println("│ " + "\x1b[1m\x1b[36m" + "Component" + "\x1b[0m" + "      │ " + "\x1b[1m\x1b[36m" + "Status" + "\x1b[0m" + "   │ " + "\x1b[1m\x1b[36m" + "Uptime" + "\x1b[0m" + "     │")
    println("├────────────────┼──────────┼────────────┤")
    println("│ Web Server     │ " + "\x1b[32m✓ Online\x1b[0m" + " │ 99.99%     │")
    println("│ Database       │ " + "\x1b[32m✓ Online\x1b[0m" + " │ 99.95%     │")
    println("│ Cache          │ " + "\x1b[33m⚠ Warning\x1b[0m" + "│ 98.50%     │")
    println("│ Queue          │ " + "\x1b[31m✗ Offline\x1b[0m" + "│ 0.00%      │")
    println("└────────────────┴──────────┴────────────┘")
    println()
}

