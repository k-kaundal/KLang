    println("\x1b[36m[1/4]\x1b[0m Compiling source files...")
    println("\x1b[32m[████████████████████████████████████████]\x1b[0m \x1b[32m100%\x1b[0m")
    println()
    println("\x1b[36m[2/4]\x1b[0m Running tests...")
    println("\x1b[32m[████████████████████████████████████████]\x1b[0m \x1b[32m100%\x1b[0m")
    println()
    println("\x1b[36m[3/4]\x1b[0m Generating documentation...")
    println("\x1b[33m[████████████████████░░░░░░░░░░░░░░░░░░░░]\x1b[0m \x1b[33m50%\x1b[0m")
    println()
    println("\x1b[36m[4/4]\x1b[0m Packaging...")
    println("\x1b[31m[████░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░]\x1b[0m \x1b[31m10%\x1b[0m")
    println()
    
    # Test results
    println("\x1b[1m\x1b[36m" + "━━━ Test Results ━━━" + "\x1b[0m")
    println()
    println("┌───────────────────┬─────────┬─────────┬─────────┐")
    println("│ " + "\x1b[1m\x1b[36m" + "Test Suite" + "\x1b[0m" + "        │ " + "\x1b[1m\x1b[36m" + "Passed" + "\x1b[0m" + "  │ " + "\x1b[1m\x1b[36m" + "Failed" + "\x1b[0m" + "  │ " + "\x1b[1m\x1b[36m" + "Skipped" + "\x1b[0m" + " │")
    println("├───────────────────┼─────────┼─────────┼─────────┤")
    println("│ Unit Tests        │ " + "\x1b[32m123\x1b[0m" + "     │ " + "\x1b[31m0\x1b[0m" + "       │ " + "\x1b[33m0\x1b[0m" + "       │")
    println("│ Integration Tests │ " + "\x1b[32m45\x1b[0m" + "      │ " + "\x1b[31m2\x1b[0m" + "       │ " + "\x1b[33m1\x1b[0m" + "       │")
    println("│ E2E Tests         │ " + "\x1b[32m12\x1b[0m" + "      │ " + "\x1b[31m0\x1b[0m" + "       │ " + "\x1b[33m3\x1b[0m" + "       │")
    println("└───────────────────┴─────────┴─────────┴─────────┘")
    println()
    
