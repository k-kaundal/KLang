# Main entry point for example-blog-api
import server from "stdlib/server"
import app from "./app"

# Get port from environment or use default
let port = env.get("PORT") || 3000

# Start the server
app.listen(port)

println(`🚀 Server running on http://localhost:${port}`)
println(`📚 Environment: ${env.get("NODE_ENV") || "development"}`)
println("")
println("Press Ctrl+C to stop")
