# ============================================
# Working AI-Native Demo - Built-in Functions Only
# ============================================
# Demonstrates built-in AI features without stdlib imports

println("=== KLang AI-Native Core Features Demo ===\n")

# Test 1: Environment Variables
println("--- Test 1: Environment Variables ---")

# Set and get environment variables
env.set("TEST_KEY", "test_value_123")
env.set("AI_MODEL", "gpt-4")
env.set("AI_TEMP", "0.7")

let testVal = env.get("TEST_KEY")
println("env.get('TEST_KEY'): " + testVal)

let model = env.get("AI_MODEL")
println("env.get('AI_MODEL'): " + model)

let hasKey = env.has("TEST_KEY")
println("env.has('TEST_KEY'): " + str(hasKey))

let missingKey = env.has("NONEXISTENT")
println("env.has('NONEXISTENT'): " + str(missingKey))

println("✓ Environment variables working!\n")

# Test 2: API Key Pattern
println("--- Test 2: API Key Management Pattern ---")

# Simulate loading API key
env.set("OPENAI_API_KEY", "sk-test-1234567890abcdef")
let apiKey = env.get("OPENAI_API_KEY")

if apiKey != null && len(apiKey) > 0 {
    println("✓ API key loaded: " + substring(apiKey, 0, 10) + "...")
    println("  (In production, this would be your real API key)")
} else {
    println("✗ API key not found")
}
println()

# Test 3: Configuration Storage
println("--- Test 3: Configuration via Environment ---")

# Store multiple config values
env.set("LLM_PROVIDER", "openai")
env.set("LLM_MODEL", "gpt-4")
env.set("LLM_TEMPERATURE", "0.7")
env.set("LLM_MAX_TOKENS", "1000")

# Retrieve configuration
let provider = env.get("LLM_PROVIDER")
let llmModel = env.get("LLM_MODEL")
let temperature = env.get("LLM_TEMPERATURE")
let maxTokens = env.get("LLM_MAX_TOKENS")

println("Configuration loaded:")
println("  Provider: " + provider)
println("  Model: " + llmModel)
println("  Temperature: " + temperature)
println("  Max Tokens: " + maxTokens)
println()

# Test 4: HTTP Client Structure
println("--- Test 4: HTTP Client API ---")

println("HTTP functions available:")
println("  http.get(url) - GET request")
println("  http.post(url, body) - POST request")
println("  http.request(config) - Advanced request with headers")
println()

println("Example usage:")
println('  let response = http.get("https://api.example.com/data")')
println('  let result = http.post("https://api.example.com", jsonBody)')
println()

# Test 5: AI Feature Files
println("--- Test 5: AI Standard Library Modules ---")

let modules = [
    "stdlib/ai.kl",
    "stdlib/llm.kl",
    "stdlib/embedding.kl",
    "stdlib/prompt.kl",
    "stdlib/rag.kl",
    "stdlib/agents.kl"
]

println("Checking AI modules:")
let i = 0
while i < len(modules) {
    if fexists(modules[i]) {
        let size = fsize(modules[i])
        println("  ✓ " + modules[i] + " (" + str(size) + " bytes)")
    } else {
        println("  ✗ " + modules[i] + " (not found)")
    }
    i = i + 1
}
println()

