# Test 8: Real-world Patterns
println("--- Test 8: Real-world Usage Patterns ---")

println("Pattern 1: Secure API Key Loading")
println("  let apiKey = env.get('OPENAI_API_KEY')")
println("  if apiKey == null { exit() }")
println()

println("Pattern 2: LLM API Call Structure")
println("  let config = dict()")
println("  config.set('url', apiUrl)")
println("  config.set('method', 'POST')")
println("  config.set('body', jsonBody)")
println("  let response = http.request(config)")
println()

println("Pattern 3: RAG Pipeline")
println("  1. Chunk documents → TextChunker")
println("  2. Generate embeddings → client.embed()")
println("  3. Store in vector DB → VectorDB")
println("  4. Semantic search → store.search()")
println("  5. Build RAG prompt → RAGPrompt")
println("  6. Generate answer → client.complete()")
println()

