# Absolute value
println("abs(-42) = ")
print(abs(-42))
println("")

# Min/Max
println("min(15, 30) = ")
print(min(15, 30))
println("")
println("max(15, 30) = ")
print(max(15, 30))
println("")

# Power function (from stdlib/math.kl)
fn pow(base: int, exp: int) -> int {
    if exp == 0 {
        return 1
    }
    let result = 1
    let i = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    return result
}

println("pow(2, 10) = ")
print(pow(2, 10))
println("")

# Factorial (from stdlib/math.kl)
fn factorial(n: int) -> int {
    if n <= 1 {
        return 1
    }
    let result = 1
    let i = 2
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}

println("factorial(7) = ")
print(factorial(7))
println("")

# GCD (from stdlib/math.kl)
fn gcd(a: int, b: int) -> int {
    let x = a
    let y = b
    if x < 0 {
        x = 0 - x
    }
    if y < 0 {
        y = 0 - y
    }
    while y != 0 {
        let temp = y
        y = x % y
        x = temp
    }
    return x
}

println("gcd(56, 98) = ")
print(gcd(56, 98))
println("")

# Even/Odd check
fn isEven(n: int) -> int {
    if n % 2 == 0 {
        return 1
    }
    return 0
}

println("isEven(42) = ")
print(isEven(42))
println(" (1 = true)")

# Clamp (from stdlib/math.kl)
fn clamp(value: int, minVal: int, maxVal: int) -> int {
    if value < minVal {
        return minVal
    }
    if value > maxVal {
        return maxVal
    }
    return value
}

println("clamp(250, 0, 100) = ")
print(clamp(250, 0, 100))
println("")
println("")

# ============================================================
# PART 3: String Library Functions
# ============================================================
println("📝 PART 3: String Library Functions (5 functions)")
println("═══════════════════════════════════════════════════════════")

# String repeat (from stdlib/string.kl)
fn repeat(s: string, n: int) -> string {
    let result = ""
    let i = 0
    while i < n {
        result = result + s
        i = i + 1
    }
    return result
}

println("repeat('KLang! ', 4) = ")
println(repeat("KLang! ", 4))

# String length check
let myString = "Hello, World!"
println("len('Hello, World!') = ")
print(len(myString))
println("")
println("")

# ============================================================
# PART 4: Core Utility Functions
# ============================================================
println("🛠️  PART 4: Core Utility Functions (11 functions)")
println("═══════════════════════════════════════════════════════════")

# Sign function (from stdlib/core.kl)
fn sign(n: int) -> int {
    if n < 0 {
        return 0 - 1
    }
    if n > 0 {
        return 1
    }
    return 0
}

println("sign(-99) = ")
print(sign(-99))
println("")
println("sign(0) = ")
print(sign(0))
println("")
println("sign(99) = ")
print(sign(99))
println("")

# Compare function (from stdlib/core.kl)
fn compare(a: int, b: int) -> int {
    if a < b {
        return 0 - 1
    }
    if a > b {
        return 1
    }
    return 0
}

println("compare(10, 20) = ")
print(compare(10, 20))
println(" (-1 means first < second)")

# In range check (from stdlib/core.kl)
fn inRange(value: int, minVal: int, maxVal: int) -> int {
    if value >= minVal {
        if value <= maxVal {
            return 1
        }
    }
    return 0
}

println("inRange(50, 0, 100) = ")
print(inRange(50, 0, 100))
println(" (1 = true)")
println("")

# ============================================================
# PART 5: Real-World Example
# ============================================================
println("🌟 PART 5: Real-World Example - Grade Calculator")
println("═══════════════════════════════════════════════════════════")

let score1 = 85
let score2 = 92
let score3 = 78

println("Test Scores: 85, 92, 78")

# Calculate average manually (array operations have issues)
let totalScore = score1 + score2 + score3
let avgScore = totalScore / 3

println("Average Score: ")
print(avgScore)
println("")

# Grade classification using clamp and ranges
let grade = clamp(avgScore, 0, 100)
println("Clamped Grade (0-100): ")
print(grade)
println("")

if grade >= 90 {
    println("Grade: A (Excellent!)")
}
if grade >= 80 {
    if grade < 90 {
        println("Grade: B (Good!)")
    }
}
if grade >= 70 {
    if grade < 80 {
        println("Grade: C (Average)")
    }
}
if grade < 70 {
    println("Grade: D (Needs Improvement)")
}

println("")

