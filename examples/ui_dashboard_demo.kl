# ============================================
# KLang UI Engine - Dashboard Example
# ============================================
# A comprehensive example showing the UI engine capabilities
# Similar to how you'd build a web app with HTML/CSS/JS

# This demonstrates:
# - Component composition
# - Layouts (Stack, Grid)
# - Built-in components (Container, Panel, Text, List, ProgressBar, Table)
# - Styling and theming
# - Interactive dashboard

# ===========================================
# Dashboard Application
# ===========================================

# Create the main application
fn createDashboard() {
    let app = createApp({
        "title": "KLang UI Dashboard",
        "width": 100,
        "height": 30
    })
    
    # Create root container
    let root = Container({
        "title": "System Dashboard",
        "border": true,
        "padding": 1
    })
    
    # Top stats panel
    let statsPanel = createStatsPanel()
    root.addChild(statsPanel)
    
    # Spacer
    root.addChild(Spacer({"size": 1}))
    
    # Middle section with two panels side by side
    let middleSection = createMiddleSection()
    root.addChild(middleSection)
    
    # Spacer
    root.addChild(Spacer({"size": 1}))
    
    # Bottom section with system info
    let systemPanel = createSystemPanel()
    root.addChild(systemPanel)
    
    # Set root and start
    app.setRoot(root)
    return app
}

# ===========================================
# Stats Panel
# ===========================================

fn createStatsPanel() {
    let panel = Panel({
        "title": "Quick Stats",
        "color": "cyan"
    })
    
    # CPU Usage
    let cpuBar = ProgressBar({
        "label": "CPU Usage:",
        "value": 65,
        "showPercent": true,
        "width": 50
    })
    panel.addChild(cpuBar)
    
    # Memory Usage
    let memBar = ProgressBar({
        "label": "Memory:",
        "value": 78,
        "showPercent": true,
        "width": 50
    })
    panel.addChild(memBar)
    
    # Disk Usage
    let diskBar = ProgressBar({
        "label": "Disk:",
        "value": 45,
        "showPercent": true,
        "width": 50
    })
    panel.addChild(diskBar)
    
    return panel
}

# ===========================================
# Middle Section (Services + Tasks)
# ===========================================

fn createMiddleSection() {
    let container = Container({
        "border": false,
        "padding": 0
    })
    
    # Services List
    let servicesPanel = Panel({
        "title": "Active Services",
        "color": "green"
    })
    
    let servicesList = List({
        "items": [
            "✓ Web Server - Running",
            "✓ Database - Running", 
            "✓ Cache Server - Running",
            "⚠ Mail Server - Degraded",
            "✗ Queue Worker - Stopped"
        ],
        "selectedIndex": 0,
        "showNumbers": false
    })
    servicesPanel.addChild(servicesList)
    container.addChild(servicesPanel)
    
    # Tasks Panel
    let tasksPanel = Panel({
        "title": "Recent Tasks",
        "color": "yellow"
    })
    
    let tasksList = List({
        "items": [
            "Deploy v2.5.1",
            "Database backup",
            "Clear cache",
            "Update SSL certs",
            "Review logs"
        ],
        "selectedIndex": 2,
        "showNumbers": true
    })
    tasksPanel.addChild(tasksList)
    container.addChild(tasksPanel)
    
    return container
}

# ===========================================
# System Info Panel
# ===========================================

fn createSystemPanel() {
    let panel = Panel({
        "title": "System Information",
        "color": "blue"
    })
    
    # System info table
    let table = Table({
        "headers": ["Component", "Status", "Uptime", "Load"],
        "rows": [
            ["App Server", "✓ Online", "23d 14h", "Low"],
            ["Database", "✓ Online", "23d 14h", "Medium"],
            ["Cache", "⚠ Warning", "5d 3h", "High"],
            ["Queue", "✗ Offline", "0h", "N/A"]
        ],
        "columnWidths": [15, 12, 10, 10]
    })
    panel.addChild(table)
    
    return panel
}

# ===========================================
# Main Entry Point
# ===========================================

