# Comprehensive ** Power Operator Test
# This test demonstrates all features of the ** exponentiation operator

println("=== ** Power Operator Comprehensive Test ===")
println()

# Test 1: Basic integer exponentiation
println("Test 1: Basic Integer Exponentiation")
println("2 ** 0 =", 2 ** 0)    # 1
println("2 ** 1 =", 2 ** 1)    # 2
println("2 ** 2 =", 2 ** 2)    # 4
println("2 ** 3 =", 2 ** 3)    # 8
println("2 ** 4 =", 2 ** 4)    # 16
println("2 ** 10 =", 2 ** 10)  # 1024
println()

# Test 2: Different bases
println("Test 2: Different Bases")
println("3 ** 2 =", 3 ** 2)    # 9
println("3 ** 3 =", 3 ** 3)    # 27
println("5 ** 2 =", 5 ** 2)    # 25
println("10 ** 3 =", 10 ** 3)  # 1000
println()

# Test 3: Floating point exponentiation
println("Test 3: Floating Point Exponentiation")
println("2.0 ** 2 =", 2.0 ** 2)      # 4.0
println("2.5 ** 2 =", 2.5 ** 2)      # 6.25
println("1.5 ** 3 =", 1.5 ** 3)      # 3.375
println("0.5 ** 2 =", 0.5 ** 2)      # 0.25
println()

# Test 4: Negative bases
println("Test 4: Negative Bases")
println("(-2) ** 2 =", (-2) ** 2)    # 4
println("(-2) ** 3 =", (-2) ** 3)    # -8
println("(-3) ** 2 =", (-3) ** 2)    # 9
println("(-3) ** 3 =", (-3) ** 3)    # -27
println()

# Test 5: Fractional exponents (roots)
println("Test 5: Fractional Exponents (Roots)")
println("4 ** 0.5 =", 4 ** 0.5)      # 2.0 (square root)
println("8 ** (1/3) =", 8 ** (1/3))  # 2.0 (cube root, approximately)
println("16 ** 0.25 =", 16 ** 0.25)  # 2.0 (fourth root)
println()

# Test 6: Right-associativity
println("Test 6: Right-Associativity")
println("2 ** 3 ** 2 =", 2 ** 3 ** 2)  # 512 (= 2 ** (3 ** 2) = 2 ** 9)
println("Verification: 2 ** 9 =", 2 ** 9)
println("NOT: (2 ** 3) ** 2 =", (2 ** 3) ** 2)  # Would be 64
println()

# Test 7: Operator precedence
println("Test 7: Operator Precedence")
println("2 + 3 ** 2 =", 2 + 3 ** 2)      # 11 (exponentiation before addition)
println("2 * 3 ** 2 =", 2 * 3 ** 2)      # 18 (exponentiation before multiplication)
println("10 - 2 ** 3 =", 10 - 2 ** 3)    # 2 (exponentiation before subtraction)
println("20 / 2 ** 2 =", 20 / 2 ** 2)    # 5 (exponentiation before division)
println()

# Test 8: Parentheses override precedence
println("Test 8: Parentheses Override Precedence")
println("(2 + 3) ** 2 =", (2 + 3) ** 2)  # 25
println("(2 * 3) ** 2 =", (2 * 3) ** 2)  # 36
println("(10 - 2) ** 2 =", (10 - 2) ** 2)  # 64
println()

# Test 9: Variables in exponentiation
println("Test 9: Variables in Exponentiation")
let base = 2
let exponent = 8
println("base =", base, ", exponent =", exponent)
println("base ** exponent =", base ** exponent)  # 256

let x = 3
let y = 4
println("x =", x, ", y =", y)
println("x ** y =", x ** y)  # 81
println()

# Test 10: Complex expressions
println("Test 10: Complex Expressions")
println("2 ** 3 + 3 ** 2 =", 2 ** 3 + 3 ** 2)          # 17
println("(2 ** 3) * (3 ** 2) =", (2 ** 3) * (3 ** 2))  # 72
println("5 + 2 ** 3 * 3 =", 5 + 2 ** 3 * 3)            # 29
println()

# Test 11: Scientific notation patterns
println("Test 11: Powers of 10 (Scientific Notation)")
println("10 ** 0 =", 10 ** 0)   # 1
println("10 ** 1 =", 10 ** 1)   # 10
println("10 ** 2 =", 10 ** 2)   # 100
println("10 ** 3 =", 10 ** 3)   # 1000
println("10 ** 6 =", 10 ** 6)   # 1000000 (one million)
println()

# Test 12: Comparison with Math.pow
println("Test 12: Comparison with Math.pow")
println("2 ** 8 =", 2 ** 8)
println("Math.pow(2, 8) =", Math.pow(2, 8))
println("Both give same result:", (2 ** 8) == Math.pow(2, 8))
println()

# Test 13: Real-world applications
println("Test 13: Real-World Applications")

# Compound interest: A = P(1 + r)^t
let principal = 1000
let rate = 0.05  # 5%
let years = 10
let amount = principal * (1 + rate) ** years
println("Compound Interest:")
println("  Principal: $", principal)
println("  Rate: 5%")
println("  Time: ", years, " years")
println("  Final Amount: $", amount)
println()

# Area of a square
let side = 5
let area = side ** 2
println("Square Area:")
println("  Side:", side)
println("  Area:", area)
println()

# Volume of a cube
let edge = 3
let volume = edge ** 3
println("Cube Volume:")
println("  Edge:", edge)
println("  Volume:", volume)
println()

# Test 14: Edge cases
println("Test 14: Edge Cases")
println("1 ** 100 =", 1 ** 100)   # Always 1
println("0 ** 5 =", 0 ** 5)       # Always 0
println("5 ** 0 =", 5 ** 0)       # Always 1
println()

println("=== All ** Power Operator Tests Complete! ===")
println("The ** operator works correctly in all scenarios!")
