# ============================================
# Section 5: Array Algorithms
# ============================================
println("Section 5: Array Algorithms")
println("-" * 40)

# Test 5.1: Sum elements
fn sumArray(arr) {
    let total = 0
    for (let val of arr) {
        total = total + val
    }
    return total
}
let nums = [1, 2, 3, 4, 5]
println("✓ Test 5.1: Sum [1,2,3,4,5] = " + str(sumArray(nums)))

# Test 5.2: Find minimum
fn findMin(arr) {
    if (len(arr) == 0) {
        return null
    }
    let minVal = arr[0]
    for (let val of arr) {
        if (val < minVal) {
            minVal = val
        }
    }
    return minVal
}
let testArr = [23, 5, 89, 12, 3, 67]
println("✓ Test 5.2: Min of [23,5,89,12,3,67] = " + str(findMin(testArr)))

# Test 5.3: Find maximum
fn findMax(arr) {
    if (len(arr) == 0) {
        return null
    }
    let maxVal = arr[0]
    for (let val of arr) {
        if (val > maxVal) {
            maxVal = val
        }
    }
    return maxVal
}
println("✓ Test 5.3: Max of [23,5,89,12,3,67] = " + str(findMax(testArr)))

# Test 5.4: Count occurrences
fn count(arr, target) {
    let cnt = 0
    for (let val of arr) {
        if (val == target) {
            cnt = cnt + 1
        }
    }
    return cnt
}
let countArr = [1, 3, 5, 3, 7, 3, 9]
println("✓ Test 5.4: Count 3s in array = " + str(count(countArr, 3)))

# Test 5.5: Average
fn average(arr) {
    if (len(arr) == 0) {
        return 0
    }
    return sumArray(arr) / len(arr)
}
let avgArr = [10, 20, 30, 40, 50]
println("✓ Test 5.5: Average of [10,20,30,40,50] = " + str(average(avgArr)))

println()

# ============================================
# Section 6: Array Transformation
# ============================================
println("Section 6: Array Transformation")
println("-" * 40)

# Test 6.1: Map (double each element)
fn map(arr, func) {
    let result = []
    let idx = 0
    for (let val of arr) {
        result[idx] = func(val)
        idx = idx + 1
    }
    return result
}

fn double(x) {
    return x * 2
}

let mapped = map([1, 2, 3, 4, 5], double)
print("✓ Test 6.1: Mapped (doubled): ")
for (let v of mapped) {
    print(str(v) + " ")
}
println()

# Test 6.2: Filter (keep even numbers)
fn filter(arr, predicate) {
    let result = []
    let idx = 0
    for (let val of arr) {
        if (predicate(val)) {
            result[idx] = val
            idx = idx + 1
        }
    }
    return result
}

fn isEven(x) {
    return x % 2 == 0
}

let filtered = filter([1, 2, 3, 4, 5, 6, 7, 8], isEven)
print("✓ Test 6.2: Filtered (evens): ")
for (let v of filtered) {
    print(str(v) + " ")
}
println()

# Test 6.3: Reduce (sum all)
fn reduce(arr, func, initial) {
    let acc = initial
    for (let val of arr) {
        acc = func(acc, val)
    }
    return acc
}

fn add(a, b) {
    return a + b
}

let reduced = reduce([1, 2, 3, 4, 5], add, 0)
println("✓ Test 6.3: Reduced (sum): " + str(reduced))

println()

# ============================================
# Section 7: Array Searching
# ============================================
println("Section 7: Array Searching")
println("-" * 40)

# Test 7.1: Linear search
fn indexOf(arr, target) {
    for (let i = 0; i < len(arr); i = i + 1) {
        if (arr[i] == target) {
            return i
        }
    }
    return -1
}

let searchArr = [10, 20, 30, 40, 50]
println("✓ Test 7.1: indexOf 30 = " + str(indexOf(searchArr, 30)))
println("  indexOf 99 = " + str(indexOf(searchArr, 99)))

# Test 7.2: Contains check
fn contains(arr, target) {
    return indexOf(arr, target) != -1
}

println("✓ Test 7.2: contains 40 = " + str(contains(searchArr, 40)))
println("  contains 99 = " + str(contains(searchArr, 99)))

# Test 7.3: Find first matching
fn find(arr, predicate) {
    for (let val of arr) {
        if (predicate(val)) {
            return val
        }
    }
    return null
}

fn greaterThan50(x) {
    return x > 50
}

let findArr = [10, 30, 55, 70, 90]
println("✓ Test 7.3: find first > 50 = " + str(find(findArr, greaterThan50)))

println()

# ============================================
# Section 8: Array Manipulation
# ============================================
println("Section 8: Array Manipulation")
println("-" * 40)

# Test 8.1: Reverse array
fn reverse(arr) {
    let result = []
    let len = len(arr)
    for (let i = 0; i < len; i = i + 1) {
        result[i] = arr[len - 1 - i]
    }
    return result
}

let rev = reverse([1, 2, 3, 4, 5])
print("✓ Test 8.1: Reversed: ")
for (let v of rev) {
    print(str(v) + " ")
}
println()

# Test 8.2: Slice (extract portion)
fn slice(arr, start, end) {
    let result = []
    let idx = 0
    for (let i = start; i < end && i < len(arr); i = i + 1) {
        result[idx] = arr[i]
        idx = idx + 1
    }
    return result
}

let sliced = slice([0, 1, 2, 3, 4, 5], 2, 5)
print("✓ Test 8.2: Slice [2:5]: ")
for (let v of sliced) {
    print(str(v) + " ")
}
println()

# Test 8.3: Concatenate arrays
fn concat(arr1, arr2) {
    let result = []
    let idx = 0
    for (let v of arr1) {
        result[idx] = v
        idx = idx + 1
    }
    for (let v of arr2) {
        result[idx] = v
        idx = idx + 1
    }
    return result
}

let concated = concat([1, 2, 3], [4, 5, 6])
print("✓ Test 8.3: Concatenated: ")
for (let v of concated) {
    print(str(v) + " ")
}
println()

# Test 8.4: Remove duplicates
fn unique(arr) {
    let result = []
    let idx = 0
    for (let val of arr) {
        if (!contains(result, val)) {
            result[idx] = val
            idx = idx + 1
        }
    }
    return result
}

let uniq = unique([1, 2, 2, 3, 3, 3, 4, 5, 5])
print("✓ Test 8.4: Unique: ")
for (let v of uniq) {
    print(str(v) + " ")
}
println()

println()

# ============================================
# Section 9: Sorting (Bubble Sort)
# ============================================
println("Section 9: Sorting")
println("-" * 40)

# Test 9.1: Bubble sort
fn bubbleSort(arr) {
    let n = len(arr)
    for (let i = 0; i < n - 1; i = i + 1) {
        for (let j = 0; j < n - i - 1; j = j + 1) {
            if (arr[j] > arr[j + 1]) {
                let temp = arr[j]
                arr[j] = arr[j + 1]
                arr[j + 1] = temp
            }
        }
    }
    return arr
}

let unsorted = [64, 34, 25, 12, 22, 11, 90]
let sorted = bubbleSort(unsorted)
print("✓ Test 9.1: Sorted: ")
for (let v of sorted) {
    print(str(v) + " ")
}
println()

println()

