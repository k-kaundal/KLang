# Section 10: Complex Array Operations
# ============================================
println("Section 10: Complex Operations")
println("-" * 40)

# Test 10.1: Flatten nested array
fn flatten(arr) {
    let result = []
    let idx = 0
    for (let item of arr) {
        # Check if item is array (simplified - check if has length)
        if (typeof(len(item)) != "undefined") {
            for (let subitem of item) {
                result[idx] = subitem
                idx = idx + 1
            }
        } else {
            result[idx] = item
            idx = idx + 1
        }
    }
    return result
}

let nestedFlat = [[1, 2], [3, 4], [5, 6]]
let flat = flatten(nestedFlat)
print("✓ Test 10.1: Flattened: ")
for (let v of flat) {
    print(str(v) + " ")
}
println()

# Test 10.2: Zip two arrays
fn zip(arr1, arr2) {
    let result = []
    let minLen = len(arr1)
    if (len(arr2) < minLen) {
        minLen = len(arr2)
    }
    for (let i = 0; i < minLen; i = i + 1) {
        result[i] = [arr1[i], arr2[i]]
    }
    return result
}

let zipped = zip([1, 2, 3], ["a", "b", "c"])
print("✓ Test 10.2: Zipped: ")
for (let pair of zipped) {
    print("[" + str(pair[0]) + "," + pair[1] + "] ")
}
println()

# Test 10.3: Partition array
fn partition(arr, predicate) {
    let truthy = []
    let falsy = []
    let tIdx = 0
    let fIdx = 0
    for (let val of arr) {
        if (predicate(val)) {
            truthy[tIdx] = val
            tIdx = tIdx + 1
        } else {
            falsy[fIdx] = val
            fIdx = fIdx + 1
        }
    }
    return [truthy, falsy]
}

let partitioned = partition([1, 2, 3, 4, 5, 6], isEven)
print("✓ Test 10.3: Partitioned evens: ")
for (let v of partitioned[0]) {
    print(str(v) + " ")
}
print("| odds: ")
for (let v of partitioned[1]) {
    print(str(v) + " ")
}
println()

println()

