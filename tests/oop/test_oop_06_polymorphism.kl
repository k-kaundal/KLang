# Section 1: Runtime Polymorphism - Basic Concepts
println("Section 1: Runtime Polymorphism - Basic Concepts")
println("----------------------------------------")

class Animal {
    let name: string = ""
    
    fn init(n: string) {
        this.name = n
    }
    
    fn speak() {
        println("Generic animal sound")
    }
}

class Dog extends Animal {
    fn init(n: string) {
        super.init(n)
    }
    
    fn speak() {
        println("Woof! Woof!")
    }
}

class Cat extends Animal {
    fn init(n: string) {
        super.init(n)
    }
    
    fn speak() {
        println("Meow!")
    }
}

let animal1 = new Dog("Buddy")
let animal2 = new Cat("Whiskers")

println("PASS Test 1.1: Parent reference to child object")
print("  Dog speaking: ")
animal1.speak()
print("  Cat speaking: ")
animal2.speak()

println("PASS Test 1.2: Dynamic method dispatch")
animal1.speak()

let animal3 = new Dog("Max")
animal4.speak()

println()

# Section 2: Shape Hierarchy
println("Section 2: Shape Hierarchy")
println("----------------------------------------")

class Shape {
    let color: string = ""
    
    fn init(c: string) {
        this.color = c
    }
    
    fn area() -> float {
        return 0.0
    }
    
    fn draw() {
        println("Drawing shape")
    }
}

class Circle extends Shape {
    let radius: float = 0.0
    
    fn init(c: string, r: float) {
        super.init(c)
        this.radius = r
    }
    
    fn area() -> float {
        return 3.14159 * this.radius * this.radius
    }
    
    fn draw() {
        println("Drawing " + this.color + " circle")
    }
}

class Rectangle extends Shape {
    let width: float = 0.0
    let height: float = 0.0
    
    fn init(c: string, w: float, h: float) {
        super.init(c)
        this.width = w
        this.height = h
    }
    
    fn area() -> float {
        return this.width * this.height
    }
    
    fn draw() {
        println("Drawing " + this.color + " rectangle")
    }
}

println("PASS Test 2.1: Shape polymorphism")
let shape1 = new Circle("Red", 5.0)
let shape2 = new Rectangle("Blue", 4.0, 6.0)

shape1.draw()
println("  Area: " + str(shape1.area()))

shape2.draw()
println("  Area: " + str(shape2.area()))

println("PASS Test 2.2: Total area calculation")
let totalArea = shape1.area() + shape2.area()
println("  Total: " + str(totalArea))

println()

# Section 3: Payment System
println("Section 3: Payment System")
println("----------------------------------------")

class Payment {
    let amount: float = 0.0
    
    fn init(amt: float) {
        this.amount = amt
    }
    
    fn processPayment() {
        println("Processing payment: $" + str(this.amount))
    }
}

class CreditCardPayment extends Payment {
    fn init(amt: float) {
        super.init(amt)
    }
    
    fn processPayment() {
        println("Credit card: $" + str(this.amount) + " - Approved")
    }
}

class CashPayment extends Payment {
    fn init(amt: float) {
        super.init(amt)
    }
    
    fn processPayment() {
        println("Cash: $" + str(this.amount) + " - Received")
    }
}

println("PASS Test 3.1: Payment polymorphism")
let payment1 = new CreditCardPayment(150.0)
let payment2 = new CashPayment(50.0)

payment1.processPayment()
payment2.processPayment()

println()

# Section 4: Reusability
println("Section 4: Code Reusability")
println("----------------------------------------")

fn makeAnimalSpeak(a: Animal) {
    a.speak()
}

println("PASS Test 4.1: Reusable polymorphic function")
let dog1 = new Dog("Charlie")
let cat1 = new Cat("Mittens")

makeAnimalSpeak(dog1)
makeAnimalSpeak(cat1)

println()

