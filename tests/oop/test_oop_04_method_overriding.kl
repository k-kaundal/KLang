# Section 1: Basic Method Override
println("Section 1: Basic Method Override")
println("----------------------------------------")

# Test 1.1: Simple method override
class BaseClass {
    fn greet() {
        println("Hello from BaseClass")
    }
}

class DerivedClass extends BaseClass {
    fn greet() {
        println("Hello from DerivedClass")
    }
}

let obj = new DerivedClass()
print("PASS Test 1.1: Simple override: ")
obj.greet()

# Test 1.2: Override method with parameters
class Calculator {
    fn calculate(a: int, b: int) -> int {
        return a + b
    }
}

class AdvancedCalculator extends Calculator {
    fn calculate(a: int, b: int) -> int {
        return a * b
    }
}

let calc = new AdvancedCalculator()
let result = calc.calculate(5, 3)
println("PASS Test 1.2: Override with parameters: 5 * 3 = " + str(result))

# Test 1.3: Override method with return value
class NumberGenerator {
    fn generate() -> int {
        return 10
    }
}

class CustomGenerator extends NumberGenerator {
    fn generate() -> int {
        return 42
    }
}

let gen = new CustomGenerator()
println("PASS Test 1.3: Override with return: " + str(gen.generate()))

println()

# Section 2: Override with Super
println("Section 2: Override with Super")
println("----------------------------------------")

# Test 2.1: Calling parent method with super
class Logger {
    fn log(message: string) {
        println("[LOG] " + message)
    }
}

class TimestampLogger extends Logger {
    fn log(message: string) {
        println("[TIMESTAMP] 2024-01-15")
        super.log(message)
    }
}

let logger = new TimestampLogger()
println("PASS Test 2.1: Super method call:")
logger.log("System started")

# Test 2.2: Augmenting parent behavior
class Counter {
    let count: int = 0
    
    fn increment() {
        this.count = this.count + 1
    }
    
    fn getValue() -> int {
        return this.count
    }
}

class DoubleCounter extends Counter {
    fn increment() {
        super.increment()
        super.increment()
    }
}

let counter = new DoubleCounter()
counter.increment()
println("PASS Test 2.2: Augmented behavior: " + str(counter.getValue()))

# Test 2.3: Super in constructor override
class Product {
    let name: string = ""
    let price: float = 0.0
    
    fn init(n: string, p: float) {
        this.name = n
        this.price = p
    }
    
    fn displayInfo() {
        println("Product: " + this.name)
        println("Price: $" + str(this.price))
    }
}

class DiscountProduct extends Product {
    let discount: float = 0.0
    
    fn init(n: string, p: float, d: float) {
        super.init(n, p)
        this.discount = d
    }
    
    fn displayInfo() {
        super.displayInfo()
        let finalPrice = this.price * (1.0 - this.discount)
        println("Discount: " + str(this.discount * 100.0) + "%")
        println("Final Price: $" + str(finalPrice))
    }
}

let product = new DiscountProduct("Laptop", 1000.0, 0.15)
println("PASS Test 2.3: Super in constructor:")
product.displayInfo()

println()

# Section 3: Return Type Consistency
println("Section 3: Return Type Consistency")
println("----------------------------------------")

# Test 3.1: Same return type override
class MathOperation {
    fn compute(x: float) -> float {
        return x
    }
}

class SquareOperation extends MathOperation {
    fn compute(x: float) -> float {
        return x * x
    }
}

let mathOp = new SquareOperation()
println("PASS Test 3.1: Same return type: 4.0^2 = " + str(mathOp.compute(4.0)))

# Test 3.2: String return type override
class MessageProvider {
    fn getMessage() -> string {
        return "Default message"
    }
}

class CustomMessageProvider extends MessageProvider {
    fn getMessage() -> string {
        return "Custom message from override"
    }
}

let msgProvider = new CustomMessageProvider()
println("PASS Test 3.2: String return override: " + msgProvider.getMessage())

# Test 3.3: Boolean return type override
class Validator {
    fn validate(value: int) -> bool {
        return true
    }
}

class RangeValidator extends Validator {
    fn validate(value: int) -> bool {
        return value >= 0 && value <= 100
    }
}

let validator = new RangeValidator()
println("PASS Test 3.3: Boolean return override: 50 is valid = " + str(validator.validate(50)))

println()

# Section 4: Multiple Overrides
println("Section 4: Multiple Overrides")
println("----------------------------------------")

# Test 4.1: Multiple children overriding same method
class Printer {
    fn print(text: string) {
        println(text)
    }
}

class UppercasePrinter extends Printer {
    fn print(text: string) {
        println("UPPERCASE: " + text)
    }
}

class PrefixPrinter extends Printer {
    fn print(text: string) {
        println(">>> " + text)
    }
}

let printer1 = new UppercasePrinter()
let printer2 = new PrefixPrinter()
println("PASS Test 4.1: Multiple overrides:")
printer1.print("Hello World")
printer2.print("Hello World")

# Test 4.2: Override chain in multi-level inheritance
class Level1 {
    fn process() {
        println("Level 1 processing")
    }
}

class Level2 extends Level1 {
    fn process() {
        println("Level 2 processing")
    }
}

class Level3 extends Level2 {
    fn process() {
        println("Level 3 processing")
    }
}

let obj3 = new Level3()
print("PASS Test 4.2: Override chain: ")
obj3.process()

println()

# Section 5: Practical Example - Shape Hierarchy
println("Section 5: Practical Example - Shape Hierarchy")
println("----------------------------------------")

# Test 5.1: Shape area calculation
class Shape {
    let name: string = ""
    
    fn init(n: string) {
        this.name = n
    }
    
    fn area() -> float {
        return 0.0
    }
    
    fn draw() {
        println("Drawing " + this.name)
    }
}

class Rectangle extends Shape {
    let width: float = 0.0
    let height: float = 0.0
    
    fn init(w: float, h: float) {
        super.init("Rectangle")
        this.width = w
        this.height = h
    }
    
    fn area() -> float {
        return this.width * this.height
    }
    
    fn draw() {
        super.draw()
        println("Width: " + str(this.width) + ", Height: " + str(this.height))
    }
}

class Circle extends Shape {
    let radius: float = 0.0
    
    fn init(r: float) {
        super.init("Circle")
        this.radius = r
    }
    
    fn area() -> float {
        return 3.14159 * this.radius * this.radius
    }
    
    fn draw() {
        super.draw()
        println("Radius: " + str(this.radius))
    }
}

class Triangle extends Shape {
    let base: float = 0.0
    let height: float = 0.0
    
    fn init(b: float, h: float) {
        super.init("Triangle")
        this.base = b
        this.height = h
    }
    
    fn area() -> float {
        return 0.5 * this.base * this.height
    }
    
    fn draw() {
        super.draw()
        println("Base: " + str(this.base) + ", Height: " + str(this.height))
    }
}

let rect = new Rectangle(10.0, 5.0)
let circle = new Circle(7.0)
let triangle = new Triangle(6.0, 8.0)

println("PASS Test 5.1: Shape area calculations:")
println("Rectangle area: " + str(rect.area()))
println("Circle area: " + str(circle.area()))
println("Triangle area: " + str(triangle.area()))

println()

# Test 5.2: Shape drawing
println("PASS Test 5.2: Shape drawing:")
rect.draw()
println()
circle.draw()
println()
triangle.draw()

println()

# Section 6: Practical Example - Vehicle Hierarchy
println("Section 6: Practical Example - Vehicle Hierarchy")
println("----------------------------------------")

# Test 6.1: Vehicle start/stop methods
class Vehicle {
    let brand: string = ""
    let model: string = ""
    
    fn init(b: string, m: string) {
        this.brand = b
        this.model = m
    }
    
    fn start() {
        println("Starting vehicle...")
    }
    
    fn stop() {
        println("Stopping vehicle...")
    }
    
    fn getInfo() -> string {
        return this.brand + " " + this.model
    }
}

class Car extends Vehicle {
    fn init(b: string, m: string) {
        super.init(b, m)
    }
    
    fn start() {
        println("Car engine starting: " + this.getInfo())
        println("Turning key... Engine running!")
    }
    
    fn stop() {
        println("Car engine stopping: " + this.getInfo())
        println("Engine off. Parking brake engaged.")
    }
}

class Motorcycle extends Vehicle {
    fn init(b: string, m: string) {
        super.init(b, m)
    }
    
    fn start() {
        println("Motorcycle starting: " + this.getInfo())
        println("Kickstart... Vroom!")
    }
    
    fn stop() {
        println("Motorcycle stopping: " + this.getInfo())
        println("Engine off. Kickstand down.")
    }
}

class ElectricCar extends Vehicle {
    fn init(b: string, m: string) {
        super.init(b, m)
    }
    
    fn start() {
        println("Electric car starting: " + this.getInfo())
        println("Silent electric motor ready!")
    }
    
    fn stop() {
        println("Electric car stopping: " + this.getInfo())
        println("Motor off. Battery charging.")
    }
}

println("PASS Test 6.1: Vehicle operations:")
let car = new Car("Toyota", "Camry")
car.start()
car.stop()
println()

let motorcycle = new Motorcycle("Harley", "Sportster")
motorcycle.start()
motorcycle.stop()
println()

let electricCar = new ElectricCar("Tesla", "Model 3")
electricCar.start()
electricCar.stop()

println()

# Section 7: Practical Example - Employee Salary
println("Section 7: Practical Example - Employee Salary")
println("----------------------------------------")

# Test 7.1: Complex salary calculation
class Employee {
    let name: string = ""
    let id: int = 0
    let baseSalary: float = 0.0
    
    fn init(n: string, empId: int, salary: float) {
        this.name = n
        this.id = empId
        this.baseSalary = salary
    }
    
    fn calculateSalary() -> float {
        return this.baseSalary
    }
    
    fn displaySalaryInfo() {
        println("Employee: " + this.name + " (ID: " + str(this.id) + ")")
        println("Total Salary: $" + str(this.calculateSalary()))
    }
}

class Manager extends Employee {
    let bonus: float = 0.0
    let teamSize: int = 0
    
    fn init(n: string, empId: int, salary: float, b: float, team: int) {
        super.init(n, empId, salary)
        this.bonus = b
        this.teamSize = team
    }
    
    fn calculateSalary() -> float {
        let teamBonus = float(this.teamSize) * 500.0
        return this.baseSalary + this.bonus + teamBonus
    }
    
    fn displaySalaryInfo() {
        super.displaySalaryInfo()
        println("Team Size: " + str(this.teamSize))
        println("Bonus: $" + str(this.bonus))
    }
}

class Developer extends Employee {
    let skillLevel: int = 0
    let projectsCompleted: int = 0
    
    fn init(n: string, empId: int, salary: float, skill: int, projects: int) {
        super.init(n, empId, salary)
        this.skillLevel = skill
        this.projectsCompleted = projects
    }
    
    fn calculateSalary() -> float {
        let skillBonus = float(this.skillLevel) * 1000.0
        let projectBonus = float(this.projectsCompleted) * 2000.0
        return this.baseSalary + skillBonus + projectBonus
    }
    
    fn displaySalaryInfo() {
        super.displaySalaryInfo()
        println("Skill Level: " + str(this.skillLevel))
        println("Projects Completed: " + str(this.projectsCompleted))
    }
}

class Intern extends Employee {
    let hoursWorked: int = 0
    let hourlyRate: float = 0.0
    
    fn init(n: string, empId: int, hours: int, rate: float) {
        super.init(n, empId, 0.0)
        this.hoursWorked = hours
        this.hourlyRate = rate
    }
    
    fn calculateSalary() -> float {
        return float(this.hoursWorked) * this.hourlyRate
    }
    
    fn displaySalaryInfo() {
        super.displaySalaryInfo()
        println("Hours Worked: " + str(this.hoursWorked))
        println("Hourly Rate: $" + str(this.hourlyRate))
    }
}

println("PASS Test 7.1: Employee salary calculations:")
println()

let manager = new Manager("Alice Johnson", 101, 80000.0, 15000.0, 8)
manager.displaySalaryInfo()
println()

let developer = new Developer("Bob Smith", 102, 75000.0, 5, 12)
developer.displaySalaryInfo()
println()

let intern = new Intern("Charlie Brown", 103, 160, 25.0)
intern.displaySalaryInfo()

println()

# Section 8: Liskov Substitution Principle
println("Section 8: Liskov Substitution Principle (Best Practices)")
println("----------------------------------------")

# Test 8.1: Substitutability - Parent reference to child object
class Bird {
    let name: string = ""
    
    fn init(n: string) {
        this.name = n
    }
    
    fn makeSound() {
        println("Generic bird sound")
    }
    
    fn fly() {
        println(this.name + " is flying")
    }
}

class Sparrow extends Bird {
    fn init(n: string) {
        super.init(n)
    }
    
    fn makeSound() {
        println("Chirp chirp!")
    }
}

class Eagle extends Bird {
    fn init(n: string) {
        super.init(n)
    }
    
    fn makeSound() {
        println("Screech!")
    }
}

println("PASS Test 8.1: Liskov Substitution - Behavioral consistency:")
let sparrow = new Sparrow("Sparrow")
let eagle = new Eagle("Eagle")

sparrow.makeSound()
sparrow.fly()

eagle.makeSound()
eagle.fly()

println()

# Test 8.2: Contract preservation
class PaymentProcessor {
    fn processPayment(amount: float) -> bool {
        println("Processing payment of $" + str(amount))
        return true
    }
}

class CreditCardProcessor extends PaymentProcessor {
    fn processPayment(amount: float) -> bool {
        println("Processing credit card payment of $" + str(amount))
        if amount > 0.0 {
            println("Payment successful!")
            return true
        }
        println("Payment failed!")
        return false
    }
}

class PayPalProcessor extends PaymentProcessor {
    fn processPayment(amount: float) -> bool {
        println("Processing PayPal payment of $" + str(amount))
        if amount > 0.0 {
            println("Payment successful!")
            return true
        }
        println("Payment failed!")
        return false
    }
}

println("PASS Test 8.2: Contract preservation:")
let ccProcessor = new CreditCardProcessor()
let ppProcessor = new PayPalProcessor()

let result1 = ccProcessor.processPayment(100.0)
println()
let result2 = ppProcessor.processPayment(50.0)

println()

# Section 9: Edge Cases
println("Section 9: Edge Cases")
println("----------------------------------------")

# Test 9.1: Override validation method
class DataValidator {
    fn validate(data: string) -> bool {
        return true
    }
    
    fn process(data: string) {
        if this.validate(data) {
            println("Data is valid: " + data)
        } else {
            println("Data is invalid: " + data)
        }
    }
}

class EmailValidator extends DataValidator {
    fn validate(data: string) -> bool {
        # Simple validation: check if contains @
        let hasAt = false
        let i = 0
        while i < len(data) {
            if data[i] == '@' {
                hasAt = true
            }
            i = i + 1
        }
        return hasAt
    }
}

println("PASS Test 9.1: Override validation method:")
let emailValidator = new EmailValidator()
emailValidator.process("user@example.com")
emailValidator.process("invalid-email")

println()

# Test 9.2: Override with state modification
class StateMachine {
    let state: int = 0
    
    fn init() {
        this.state = 0
    }
    
    fn transition() {
        this.state = this.state + 1
        println("State: " + str(this.state))
    }
}

class CustomStateMachine extends StateMachine {
    fn transition() {
        this.state = this.state + 2
        println("Custom State: " + str(this.state))
    }
}

println("PASS Test 9.2: Override with state modification:")
let sm = new CustomStateMachine()
sm.transition()
sm.transition()

println()

# Test 9.3: Multiple method overrides in same class
class MultiMethod {
    fn method1() {
        println("Base method1")
    }
    
    fn method2() {
        println("Base method2")
    }
    
    fn method3() {
        println("Base method3")
    }
}

class OverrideMulti extends MultiMethod {
    fn method1() {
        println("Overridden method1")
    }
    
    fn method2() {
        println("Overridden method2")
    }
    
    fn method3() {
        println("Overridden method3")
    }
}

println("PASS Test 9.3: Multiple overrides in same class:")
let multi = new OverrideMulti()
multi.method1()
multi.method2()
multi.method3()

println()

# Test 9.4: Override with complex logic
class ReportGenerator {
    fn generate(title: string, data: string) -> string {
        return "Report: " + title + " - " + data
    }
}

class DetailedReportGenerator extends ReportGenerator {
    fn generate(title: string, data: string) -> string {
        let header = "=== DETAILED REPORT ===\n"
        let body = "Title: " + title + "\n"
        let content = "Data: " + data + "\n"
        let footer = "======================\n"
        return header + body + content + footer
    }
}

println("PASS Test 9.4: Override with complex logic:")
let reportGen = new DetailedReportGenerator()
let report = reportGen.generate("Sales Q4", "Revenue: $1M")
print(report)

println()

# Test 9.5: Override calling multiple parent methods
class BaseService {
    fn initialize() {
        println("Service initialized")
    }
    
    fn cleanup() {
        println("Service cleaned up")
    }
}

class EnhancedService extends BaseService {
    fn start() {
        super.initialize()
        println("Enhanced service starting...")
        println("Enhanced service started!")
    }
    
    fn stop() {
        println("Enhanced service stopping...")
        super.cleanup()
        println("Enhanced service stopped!")
    }
}

println("PASS Test 9.5: Override calling multiple parent methods:")
let service = new EnhancedService()
service.start()
println()
service.stop()

println()

