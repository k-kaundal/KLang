# Section 11: Check Palindrome
println("Section 11: Check if Palindrome")
println("----------------------------------------")

let pal1 = [1, 2, 3, 2, 1]
let isPal1 = true
let p1Left = 0
let p1Right = 4
while (p1Left < p1Right) {
    if (pal1[p1Left] != pal1[p1Right]) {
        isPal1 = false
    }
    p1Left = p1Left + 1
    p1Right = p1Right - 1
}
println("PASS Test 11.1: [1,2,3,2,1] is palindrome? " + str(isPal1))

let pal2 = [1, 2, 3, 4]
let isPal2 = true
let p2Left = 0
let p2Right = 3
while (p2Left < p2Right) {
    if (pal2[p2Left] != pal2[p2Right]) {
        isPal2 = false
    }
    p2Left = p2Left + 1
    p2Right = p2Right - 1
}
println("PASS Test 11.2: [1,2,3,4] is palindrome? " + str(isPal2))

println("  Algorithm: Find middle, reverse second half, compare")
println("  Time: O(n), Space: O(1)")

println()

# Section 12: Sum of Elements
println("Section 12: Sum of Elements")
println("----------------------------------------")

let sumArr = [10, 20, 30, 40]
let sum = 0
let s = 0
while (s < 4) {
    sum = sum + sumArr[s]
    s = s + 1
}
println("PASS Test 12.1: Sum of [10,20,30,40] = " + str(sum))

println("  Algorithm: sum=0, traverse: sum += node.data")
println("  Time: O(n), Space: O(1)")

println()

# Section 13: Find Max and Min
println("Section 13: Find Maximum and Minimum")
println("----------------------------------------")

let maxMinArr = [64, 34, 25, 90, 12]
let maxValue = maxMinArr[0]
let minValue = maxMinArr[0]
let mm = 1
while (mm < 5) {
    if (maxMinArr[mm] > maxValue) {
        maxValue = maxMinArr[mm]
    }
    if (maxMinArr[mm] < minValue) {
        minValue = maxMinArr[mm]
    }
    mm = mm + 1
}

println("PASS Test 13.1: Max in [64,34,25,90,12] = " + str(maxValue))
println("PASS Test 13.2: Min = " + str(minValue))

println("  Algorithm: max=first, traverse: if node.data > max")
println("  Time: O(n), Space: O(1)")

println()

# Section 14: Swap Adjacent Nodes
println("Section 14: Swap Adjacent Nodes")
println("----------------------------------------")

let swapArr = [1, 2, 3, 4]
let sw = 0
while (sw < 3) {
    let temp = swapArr[sw]
    swapArr[sw] = swapArr[sw + 1]
    swapArr[sw + 1] = temp
    sw = sw + 2
}

print("PASS Test 14.1: After swap: [")
let sw2 = 0
while (sw2 < 4) {
    print(str(swapArr[sw2]))
    if (sw2 < 3) {
        print(", ")
    }
    sw2 = sw2 + 1
}
println("]")

println("  Algorithm: first.next = second.next")
println("  second.next = first, adjust pointers")
println("  Time: O(n), Space: O(1)")

println()

# Section 15: Count Occurrences
println("Section 15: Count Occurrences")
println("----------------------------------------")

let countArr = [1, 2, 2, 3, 2, 4]
let count = 0
let c = 0
while (c < 6) {
    if (countArr[c] == 2) {
        count = count + 1
    }
    c = c + 1
}
println("PASS Test 15.1: Occurrences of 2 in array = " + str(count))

println("  Algorithm: count=0, traverse: if data==target count++")
println("  Time: O(n), Space: O(1)")

println()

