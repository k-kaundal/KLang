# Section 17: Detect Cycle (Floyd's Algorithm)
println("Section 17: Detect Cycle")
println("----------------------------------------")

println("PASS Test 17.1: Floyd's Cycle Detection")
println("  Algorithm: Slow and fast pointers (Tortoise & Hare)")
println("  - Slow moves 1 step: slow = slow.next")
println("  - Fast moves 2 steps: fast = fast.next.next")
println("  - If they meet: cycle exists")
println("  - If fast reaches null: no cycle")
println("  Time: O(n), Space: O(1)")

println()

# Section 18: Reverse in Groups
println("Section 18: Reverse in Groups")
println("----------------------------------------")

let grpArr = [1, 2, 3, 4, 5, 6, 7, 8]
let grpSize = 8
let k = 3
let gIdx = 0

while (gIdx < grpSize) {
    let gLeft = gIdx
    let gRight = gIdx + k - 1
    
    if (gRight >= grpSize) {
        gRight = grpSize - 1
    }
    
    while (gLeft < gRight) {
        let temp = grpArr[gLeft]
        grpArr[gLeft] = grpArr[gRight]
        grpArr[gRight] = temp
        gLeft = gLeft + 1
        gRight = gRight - 1
    }
    
    gIdx = gIdx + k
}

print("PASS Test 18.1: Reversed in groups of 3: [")
let g = 0
while (g < grpSize) {
    print(str(grpArr[g]))
    if (g < grpSize - 1) {
        print(", ")
    }
    g = g + 1
}
println("]")

println("  Algorithm: Reverse k nodes at a time")
println("  Time: O(n), Space: O(1)")

println()

