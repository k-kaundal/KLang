# Section 5: Reverse Linked List
println("Section 5: Reverse Linked List")
println("----------------------------------------")

# Demonstrate with array
let revArr = [1, 2, 3, 4, 5]
print("Before reverse: [")
let i1 = 0
while (i1 < 5) {
    print(str(revArr[i1]))
    if (i1 < 4) {
        print(", ")
    }
    i1 = i1 + 1
}
println("]")

# Reverse using three-pointer technique
let left = 0
let right = 4
while (left < right) {
    let temp = revArr[left]
    revArr[left] = revArr[right]
    revArr[right] = temp
    left = left + 1
    right = right - 1
}

print("PASS Test 5.1: After reverse: [")
let i2 = 0
while (i2 < 5) {
    print(str(revArr[i2]))
    if (i2 < 4) {
        print(", ")
    }
    i2 = i2 + 1
}
println("]")

println("  Algorithm: prev=null, curr=head, next=null")
println("  While curr: next=curr.next, curr.next=prev, prev=curr, curr=next")
println("  Time: O(n), Space: O(1)")

println()

# Section 6: Find Middle Element
println("Section 6: Find Middle Element")
println("----------------------------------------")

let midArr1 = [1, 2, 3, 4, 5]
let middle1 = midArr1[5 / 2]
println("PASS Test 6.1: Middle of [1,2,3,4,5] = " + str(middle1))

let midArr2 = [1, 2, 3, 4]
let middle2 = midArr2[4 / 2]
println("PASS Test 6.2: Middle of [1,2,3,4] = " + str(middle2))

println("  Algorithm: Two pointers - slow and fast")
println("  Slow moves 1 step, fast moves 2 steps")
println("  When fast reaches end, slow is at middle")
println("  Time: O(n), Space: O(1)")

println()

