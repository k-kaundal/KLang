println("PASS Test 8.1: 2nd from end of [1,2,3,4,5] = " + str(second))
println("PASS Test 8.2: 4th from end = " + str(fourth))

println("  Algorithm: Two pointers n steps apart")
println("  Move first n steps, then move both until first reaches end")
println("  Time: O(n), Space: O(1)")

println()

# Section 9: Remove Duplicates
println("Section 9: Remove Duplicates from Sorted List")
println("----------------------------------------")

let dupArr = [1, 1, 2, 3, 3, 4]
print("Before: [")
let d1 = 0
while (d1 < 6) {
    print(str(dupArr[d1]))
    if (d1 < 5) {
        print(", ")
    }
    d1 = d1 + 1
}
println("]")

# Remove duplicates
let writeIdx = 1
let readIdx = 1
while (readIdx < 6) {
    if (dupArr[readIdx] != dupArr[readIdx - 1]) {
        dupArr[writeIdx] = dupArr[readIdx]
        writeIdx = writeIdx + 1
    }
    readIdx = readIdx + 1
}

print("PASS Test 9.1: After: [")
let d2 = 0
while (d2 < writeIdx) {
    print(str(dupArr[d2]))
    if (d2 < writeIdx - 1) {
        print(", ")
    }
    d2 = d2 + 1
}
println("]")

println("  Algorithm: current.next == current.data")
println("  Skip node: current.next = current.next.next")
println("  Time: O(n), Space: O(1)")

println()

