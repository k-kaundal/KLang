# Section 8: Valid Palindrome (Interview Problem)
println("Section 8: Valid Palindrome (Alphanumeric Only)")
println("----------------------------------------")

fn isAlphanumeric(ch: string) -> bool {
    # Check if character is alphanumeric (simplified)
    let code = ch[0]
    # For simplicity, we'll check common characters
    if (ch == " " || ch == "," || ch == ":" || ch == "!" || ch == "?" || ch == "." || ch == "'") {
        return false
    }
    return true
}

fn toLowerCase(ch: string) -> string {
    # Simple lowercase conversion for common uppercase letters
    if (ch == "A") { return "a" }
    if (ch == "B") { return "b" }
    if (ch == "C") { return "c" }
    if (ch == "D") { return "d" }
    if (ch == "E") { return "e" }
    if (ch == "F") { return "f" }
    if (ch == "G") { return "g" }
    if (ch == "H") { return "h" }
    if (ch == "I") { return "i" }
    if (ch == "J") { return "j" }
    if (ch == "K") { return "k" }
    if (ch == "L") { return "l" }
    if (ch == "M") { return "m" }
    if (ch == "N") { return "n" }
    if (ch == "O") { return "o" }
    if (ch == "P") { return "p" }
    if (ch == "Q") { return "q" }
    if (ch == "R") { return "r" }
    if (ch == "S") { return "s" }
    if (ch == "T") { return "t" }
    if (ch == "U") { return "u" }
    if (ch == "V") { return "v" }
    if (ch == "W") { return "w" }
    if (ch == "X") { return "x" }
    if (ch == "Y") { return "y" }
    if (ch == "Z") { return "z" }
    return ch
}

fn validPalindrome(s: string) -> bool {
    let left = 0
    let right = len(s) - 1
    
    while (left < right) {
        # Skip non-alphanumeric from left
        while (left < right && !isAlphanumeric(s[left])) {
            left = left + 1
        }
        
        # Skip non-alphanumeric from right
        while (left < right && !isAlphanumeric(s[right])) {
            right = right - 1
        }
        
        # Compare characters (case-insensitive)
        let leftChar = toLowerCase(s[left])
        let rightChar = toLowerCase(s[right])
        
        if (leftChar != rightChar) {
            return false
        }
        
        left = left + 1
        right = right - 1
    }
    
    return true
}

let vp1 = "A man, a plan, a canal: Panama"
let vp2 = "race a car"
let vp3 = "Was it a car or a cat I saw"

let isVP1 = validPalindrome(vp1)
let isVP2 = validPalindrome(vp2)
let isVP3 = validPalindrome(vp3)

println("PASS Test 8.1: 'A man, a plan, a canal: Panama' is valid palindrome = " + str(isVP1))
println("PASS Test 8.2: 'race a car' is valid palindrome = " + str(isVP2))
println("PASS Test 8.3: 'Was it a car or a cat I saw' is valid palindrome = " + str(isVP3))

println()

# Section 9: First Unique Character
println("Section 9: First Unique Character")
println("----------------------------------------")

fn firstUniqueChar(s: string) -> int {
    # Simple approach: for each position, count occurrences
    let i = 0
    while (i < len(s)) {
        let currentChar = s[i]
        let count = 0
        
        # Count this character in the entire string
        let j = 0
        while (j < len(s)) {
            if (s[j] == currentChar) {
                count = count + 1
            }
            j = j + 1
        }
        
        # If this character appears only once, return its index
        if (count == 1) {
            return i
        }
        
        i = i + 1
    }
    
    return -1
}

let uc1 = "leetcode"
let uc2 = "loveleetcode"
let uc3 = "aabb"

let ucIdx1 = firstUniqueChar(uc1)
let ucIdx2 = firstUniqueChar(uc2)
let ucIdx3 = firstUniqueChar(uc3)

println("PASS Test 9.1: First unique char in 'leetcode' at index = " + str(ucIdx1))
println("PASS Test 9.2: First unique char in 'loveleetcode' at index = " + str(ucIdx2))
println("PASS Test 9.3: First unique char in 'aabb' at index = " + str(ucIdx3))

println()

# Section 10: Longest Substring Without Repeating Characters
println("Section 10: Longest Substring Without Repeating")
println("----------------------------------------")

fn hasChar(s: string, ch: string) -> bool {
    let i = 0
    while (i < len(s)) {
        if (s[i] == ch) {
            return true
        }
        i = i + 1
    }
    return false
}

fn lengthOfLongestSubstring(s: string) -> int {
    let maxLen = 0
    let i = 0
    
    while (i < len(s)) {
        let current = ""
        let j = i
        
        while (j < len(s)) {
            let ch = s[j]
            if (hasChar(current, ch)) {
                break
            }
            current = current + ch
            j = j + 1
        }
        
        if (len(current) > maxLen) {
            maxLen = len(current)
        }
        
        i = i + 1
    }
    
    return maxLen
}

let ls1 = "abcabcbb"
let ls2 = "bbbbb"
let ls3 = "pwwkew"

let lsLen1 = lengthOfLongestSubstring(ls1)
let lsLen2 = lengthOfLongestSubstring(ls2)
let lsLen3 = lengthOfLongestSubstring(ls3)

println("PASS Test 10.1: Longest substring in 'abcabcbb' = " + str(lsLen1))
println("PASS Test 10.2: Longest substring in 'bbbbb' = " + str(lsLen2))
println("PASS Test 10.3: Longest substring in 'pwwkew' = " + str(lsLen3))

