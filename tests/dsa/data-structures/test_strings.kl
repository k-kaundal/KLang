# Section 12: String Utility Class
println("Section 12: String Utility Class")
println("----------------------------------------")

class StringUtil {
    let data: string = ""
    
    fn init(s: string) {
        this.data = s
    }
    
    fn length() -> int {
        return len(this.data)
    }
    
    fn reverse() -> string {
        let result = ""
        let i = len(this.data) - 1
        while (i >= 0) {
            result = result + this.data[i]
            i = i - 1
        }
        return result
    }
    
    fn isPalindrome() -> bool {
        let left = 0
        let right = len(this.data) - 1
        
        while (left < right) {
            if (this.data[left] != this.data[right]) {
                return false
            }
            left = left + 1
            right = right - 1
        }
        return true
    }
    
    fn charCount(ch: string) -> int {
        let count = 0
        let i = 0
        while (i < len(this.data)) {
            if (this.data[i] == ch) {
                count = count + 1
            }
            i = i + 1
        }
        return count
    }
}

let util = new StringUtil("hello")
println("PASS Test 12.1: String Utility Class")
println("  Original: '" + util.data + "'")
println("  Length: " + str(util.length()))
println("  Reverse: '" + util.reverse() + "'")
println("  Is Palindrome: " + str(util.isPalindrome()))
println("  Count 'l': " + str(util.charCount("l")))

let util2 = new StringUtil("racecar")
println("PASS Test 12.2: String Utility with 'racecar'")
println("  Is Palindrome: " + str(util2.isPalindrome()))

println()

