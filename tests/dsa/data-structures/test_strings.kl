# Section 6: Anagram Detection
println("Section 6: Anagram Detection")
println("----------------------------------------")

fn sortString(s: string) -> string {
    # Simple bubble sort for string characters
    let arr = []
    let i = 0
    while (i < len(s)) {
        arr.push(s[i])
        i = i + 1
    }
    
    # Bubble sort
    let n = len(arr)
    let k = 0
    while (k < n - 1) {
        let j = 0
        while (j < n - k - 1) {
            if (arr[j] > arr[j + 1]) {
                let temp = arr[j]
                arr[j] = arr[j + 1]
                arr[j + 1] = temp
            }
            j = j + 1
        }
        k = k + 1
    }
    
    # Convert back to string
    let result = ""
    let m = 0
    while (m < len(arr)) {
        result = result + arr[m]
        m = m + 1
    }
    return result
}

fn isAnagram(s1: string, s2: string) -> bool {
    if (len(s1) != len(s2)) {
        return false
    }
    
    return sortString(s1) == sortString(s2)
}

let ana1a = "listen"
let ana1b = "silent"
let ana2a = "evil"
let ana2b = "vile"
let ana3a = "abc"
let ana3b = "def"

let isAna1 = isAnagram(ana1a, ana1b)
let isAna2 = isAnagram(ana2a, ana2b)
let isAna3 = isAnagram(ana3a, ana3b)

println("PASS Test 6.1: 'listen' and 'silent' are anagrams = " + str(isAna1))
println("PASS Test 6.2: 'evil' and 'vile' are anagrams = " + str(isAna2))
println("PASS Test 6.3: 'abc' and 'def' are anagrams = " + str(isAna3))

println()

# Section 7: String Compression
println("Section 7: String Compression")
println("----------------------------------------")

fn compressString(s: string) -> string {
    if (len(s) == 0) {
        return ""
    }
    
    let result = ""
    let i = 0
    
    while (i < len(s)) {
        let current = s[i]
        let count = 1
        
        # Count consecutive characters
        while (i + count < len(s) && s[i + count] == current) {
            count = count + 1
        }
        
        result = result + current + str(count)
        i = i + count
    }
    
    # Return original if compressed is not smaller
    if (len(result) >= len(s)) {
        return s
    }
    
    return result
}

let comp1 = compressString("aabcccccaaa")
let comp2 = compressString("abcdef")
let comp3 = compressString("aaabbb")

println("PASS Test 7.1: Compress 'aabcccccaaa' = '" + comp1 + "'")
println("PASS Test 7.2: Compress 'abcdef' = '" + comp2 + "'")
println("PASS Test 7.3: Compress 'aaabbb' = '" + comp3 + "'")

