# Section 5: Palindrome Check
println("Section 5: Palindrome Check")
println("----------------------------------------")

fn isPalindrome(s: string) -> bool {
    let left = 0
    let right = len(s) - 1
    
    while (left < right) {
        if (s[left] != s[right]) {
            return false
        }
        left = left + 1
        right = right - 1
    }
    return true
}

