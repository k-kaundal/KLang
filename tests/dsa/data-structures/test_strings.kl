# Section 3: String Algorithms - Character Frequency
println("Section 3: Character Frequency")
println("----------------------------------------")

fn charFrequency(s: string, ch: string) -> int {
    let count = 0
    let i = 0
    while (i < len(s)) {
        if (s[i] == ch) {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

let freqStr = "hello world"
let freq_l = charFrequency(freqStr, "l")
let freq_o = charFrequency(freqStr, "o")
println("PASS Test 3.1: Frequency of 'l' in 'hello world' = " + str(freq_l))
println("PASS Test 3.2: Frequency of 'o' in 'hello world' = " + str(freq_o))

println()

# Section 4: String Reversal
println("Section 4: String Reversal")
println("----------------------------------------")

fn reverseString(s: string) -> string {
    let result = ""
    let i = len(s) - 1
    while (i >= 0) {
        result = result + s[i]
        i = i - 1
    }
    return result
}

