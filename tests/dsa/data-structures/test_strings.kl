let pal2 = "hello"
let pal3 = "madam"
let pal4 = "a"

let isPal1 = isPalindrome(pal1)
let isPal2 = isPalindrome(pal2)
let isPal3 = isPalindrome(pal3)
let isPal4 = isPalindrome(pal4)

