# Test 1.1: Simple if (true condition)
}
let x = 10
if (x > 5) {
    println("✓ Test 1.1: x is greater than 5")
}
}

# Test 1.2: Simple if (false condition)
}
if (x < 5) {
    println("✗ Test 1.2: This should NOT print")
}
} else {
    println("✓ Test 1.2: Else block executed correctly")
}
}

# Test 1.3: If with comparison operators
if (x == 10) {
    println("✓ Test 1.3a: Equality check works")
}
if (x != 5) {
    println("✓ Test 1.3b: Inequality check works")
}
if (x >= 10) {
    println("✓ Test 1.3c: Greater than or equal works")
}
if (x <= 10) {
    println("✓ Test 1.3d: Less than or equal works")
}

println()
}

