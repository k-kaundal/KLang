# Test 9.1: User authentication validator
let username = "admin"
let password = "secret123"
let isActive = true
let attempts = 2

if (username != "" && password != "") {
    if (username == "admin" && password == "secret123") {
        if (isActive) {
            if (attempts < 3) {
                println("✓ Test 9.1: Login successful")
}
            } else {
                println("✗ Test 9.1: Account locked")
}
            }
        } else {
            println("✗ Test 9.1: Account inactive")
}
        }
    } else {
        println("✗ Test 9.1: Invalid credentials")
}
    }
} else {
    println("✗ Test 9.1: Username or password empty")
}
}

# Test 9.2: Shipping cost calculator
let weight = 5
let distance = 150
let express = false
let shippingCost = 0

if (weight <= 1) {
    shippingCost = 5
} else if (weight <= 5) {
    shippingCost = 10
} else if (weight <= 10) {
    shippingCost = 15
} else {
    shippingCost = 25
}

if (distance > 100) {
    shippingCost = shippingCost + 5
}

if (express) {
    shippingCost = shippingCost * 2
}

println("✓ Test 9.2: Shipping cost is $" + str(shippingCost))
}

# Test 9.3: Date validator (simplified)
}
let day = 15
let monthNum = 2
let year = 2024
let isValid = false

if (monthNum >= 1 && monthNum <= 12) {
    if (day >= 1) {
        if (monthNum == 2) {
            if (day <= 29) {
                isValid = true
            }
        } else if (monthNum == 4 || monthNum == 6 || monthNum == 9 || monthNum == 11) {
            if (day <= 30) {
                isValid = true
            }
        } else {
            if (day <= 31) {
                isValid = true
            }
        }
    }
}

if (isValid) {
    println("✓ Test 9.3: Date is valid")
}
} else {
    println("✗ Test 9.3: Date is invalid")
}
}

println()
}

