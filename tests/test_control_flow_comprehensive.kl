# Test 2.1: Basic if-else
let age = 25
if (age >= 18) {
    println("✓ Test 2.1: Adult (age >= 18)")
}
} else {
    println("✗ Test 2.1: Minor")
}
}

# Test 2.2: If-else with expressions
let score = 85
if (score >= 90) {
    println("✗ Test 2.2: Grade A")
}
} else {
    println("✓ Test 2.2: Grade B or lower")
}
}

# Test 2.3: If-else with multiple conditions
let temperature = 75
if (temperature > 80) {
    println("✗ Test 2.3: Hot")
}
} else {
    println("✓ Test 2.3: Comfortable or cold")
}
}

println()
}

