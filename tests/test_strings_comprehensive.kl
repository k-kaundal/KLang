# ============================================
# Section 7: String Searching
# ============================================
println("Section 7: String Searching")
println("-" * 40)

# Test 7.1: Manual search
let searchStr = "Hello World"
let found = false
for (let i = 0; i < len(searchStr); i = i + 1) {
    if (searchStr[i] == "W") {
        println("✓ Test 7.1: Found 'W' at index " + str(i))
        found = true
        break
    }
}

# Test 7.2: Search for substring manually
fn contains(haystack, needle) {
    let hLen = len(haystack)
    let nLen = len(needle)
    
    if (nLen > hLen) {
        return false
    }
    
    for (let i = 0; i <= hLen - nLen; i = i + 1) {
        let match = true
        for (let j = 0; j < nLen; j = j + 1) {
            if (haystack[i + j] != needle[j]) {
                match = false
                break
            }
        }
        if (match) {
            return true
        }
    }
    return false
}

println("✓ Test 7.2: contains('Hello World', 'World'): " + str(contains("Hello World", "World")))
println("  contains('Hello World', 'xyz'): " + str(contains("Hello World", "xyz")))

# Test 7.3: Count character occurrences
fn countChar(str, ch) {
    let count = 0
    for (let c of str) {
        if (c == ch) {
            count = count + 1
        }
    }
    return count
}

println("✓ Test 7.3: Count 'l' in 'Hello': " + str(countChar("Hello", "l")))
println("  Count 'o' in 'Hello World': " + str(countChar("Hello World", "o")))

println()

# ============================================
# Section 8: String Manipulation
# ============================================
println("Section 8: String Manipulation")
println("-" * 40)

# Test 8.1: String reversal
fn reverse(str) {
    let result = ""
    for (let i = len(str) - 1; i >= 0; i = i - 1) {
        result = result + str[i]
    }
    return result
}

println("✓ Test 8.1: reverse('Hello') = " + reverse("Hello"))
println("  reverse('12345') = " + reverse("12345"))

# Test 8.2: String repeat
fn repeat(str, times) {
    let result = ""
    for (let i = 0; i < times; i = i + 1) {
        result = result + str
    }
    return result
}

println("✓ Test 8.2: repeat('Hi', 3) = " + repeat("Hi", 3))
println("  repeat('*', 5) = " + repeat("*", 5))

# Test 8.3: Substring extraction
fn substring(str, start, length) {
    let result = ""
    for (let i = 0; i < length; i = i + 1) {
        if (start + i < len(str)) {
            result = result + str[start + i]
        }
    }
    return result
}

println("✓ Test 8.3: substring('Hello World', 0, 5) = " + substring("Hello World", 0, 5))
println("  substring('Hello World', 6, 5) = " + substring("Hello World", 6, 5))

# Test 8.4: Replace character
fn replaceChar(str, oldCh, newCh) {
    let result = ""
    for (let ch of str) {
        if (ch == oldCh) {
            result = result + newCh
        } else {
            result = result + ch
        }
    }
    return result
}

println("✓ Test 8.4: replaceChar('Hello', 'l', 'x') = " + replaceChar("Hello", "l", "x"))

# Test 8.5: Remove character
fn removeChar(str, target) {
    let result = ""
    for (let ch of str) {
        if (ch != target) {
            result = result + ch
        }
    }
    return result
}

println("✓ Test 8.5: removeChar('Hello', 'l') = " + removeChar("Hello", "l"))

println()

