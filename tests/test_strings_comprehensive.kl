# Section 9: String Formatting and Building
# ============================================
println("Section 9: String Formatting")
println("-" * 40)

# Test 9.1: Build formatted string
fn formatName(first, last) {
    return last + ", " + first
}

println("✓ Test 9.1: Format name: " + formatName("John", "Doe"))

# Test 9.2: Template-like strings
fn template(name, age, city) {
    return "Name: " + name + ", Age: " + str(age) + ", City: " + city
}

println("✓ Test 9.2: " + template("Alice", 30, "NYC"))

# Test 9.3: Build CSV line
fn csvLine(fields) {
    let result = ""
    let first = true
    for (let field of fields) {
        if (!first) {
            result = result + ","
        }
        result = result + str(field)
        first = false
    }
    return result
}

println("✓ Test 9.3: CSV: " + csvLine(["John", 25, "NYC"]))

# Test 9.4: Padding
fn padLeft(str, width, padChar) {
    let result = str
    while (len(result) < width) {
        result = padChar + result
    }
    return result
}

println("✓ Test 9.4: padLeft('42', 5, '0') = " + padLeft("42", 5, "0"))

# Test 9.5: Centering
fn center(str, width) {
    let totalPad = width - len(str)
    if (totalPad <= 0) {
        return str
    }
    let leftPad = totalPad / 2
    let rightPad = totalPad - leftPad
    let result = repeat(" ", leftPad) + str + repeat(" ", rightPad)
    return result
}

println("✓ Test 9.5: center('Hi', 10) = '" + center("Hi", 10) + "'")

println()

# ============================================
# Section 10: String Validation
# ============================================
println("Section 10: String Validation")
println("-" * 40)

# Test 10.1: Check if all digits
fn isDigits(str) {
    if (len(str) == 0) {
        return false
    }
    for (let ch of str) {
        if (ch < "0" || ch > "9") {
            return false
        }
    }
    return true
}

println("✓ Test 10.1: isDigits('12345'): " + str(isDigits("12345")))
println("  isDigits('123a5'): " + str(isDigits("123a5")))

# Test 10.2: Check if all letters (simplified)
fn isAlpha(str) {
    if (len(str) == 0) {
        return false
    }
    for (let ch of str) {
        let isUpper = (ch >= "A" && ch <= "Z")
        let isLower = (ch >= "a" && ch <= "z")
        if (!isUpper && !isLower) {
            return false
        }
    }
    return true
}

println("✓ Test 10.2: isAlpha('Hello'): " + str(isAlpha("Hello")))
println("  isAlpha('Hello123'): " + str(isAlpha("Hello123")))

# Test 10.3: Check if empty or whitespace
fn isBlank(str) {
    if (len(str) == 0) {
        return true
    }
    for (let ch of str) {
        if (ch != " " && ch != "\t" && ch != "\n") {
            return false
        }
    }
    return true
}

println("✓ Test 10.3: isBlank(''): " + str(isBlank("")))
println("  isBlank('   '): " + str(isBlank("   ")))
println("  isBlank(' x '): " + str(isBlank(" x ")))

# Test 10.4: Starts with
fn startsWith(str, prefix) {
    if (len(prefix) > len(str)) {
        return false
    }
    for (let i = 0; i < len(prefix); i = i + 1) {
        if (str[i] != prefix[i]) {
            return false
        }
    }
    return true
}

println("✓ Test 10.4: startsWith('Hello', 'He'): " + str(startsWith("Hello", "He")))
println("  startsWith('Hello', 'Hi'): " + str(startsWith("Hello", "Hi")))

# Test 10.5: Ends with
fn endsWith(str, suffix) {
    let sLen = len(str)
    let sufLen = len(suffix)
    if (sufLen > sLen) {
        return false
    }
    let offset = sLen - sufLen
    for (let i = 0; i < sufLen; i = i + 1) {
        if (str[offset + i] != suffix[i]) {
            return false
        }
    }
    return true
}

println("✓ Test 10.5: endsWith('Hello', 'lo'): " + str(endsWith("Hello", "lo")))
println("  endsWith('Hello', 'la'): " + str(endsWith("Hello", "la")))

println()

# ============================================
# Section 11: String Trimming
# ============================================
println("Section 11: String Trimming")
println("-" * 40)

# Test 11.1: Trim left
fn trimLeft(str) {
    let start = 0
    while (start < len(str) && str[start] == " ") {
        start = start + 1
    }
    return substring(str, start, len(str) - start)
}

println("✓ Test 11.1: trimLeft('  Hello') = '" + trimLeft("  Hello") + "'")

# Test 11.2: Trim right
fn trimRight(str) {
    let end = len(str) - 1
    while (end >= 0 && str[end] == " ") {
        end = end - 1
    }
    return substring(str, 0, end + 1)
}

println("✓ Test 11.2: trimRight('Hello  ') = '" + trimRight("Hello  ") + "'")

# Test 11.3: Trim both
fn trim(str) {
    return trimLeft(trimRight(str))
}

println("✓ Test 11.3: trim('  Hello  ') = '" + trim("  Hello  ") + "'")

println()

# ============================================
# Section 12: Complex String Operations
# ============================================
println("Section 12: Complex Operations")
println("-" * 40)

# Test 12.1: Word count
fn wordCount(str) {
    let count = 0
    let inWord = false
    for (let ch of str) {
        if (ch == " ") {
            inWord = false
        } else {
            if (!inWord) {
                count = count + 1
                inWord = true
            }
        }
    }
    return count
}

println("✓ Test 12.1: wordCount('Hello World'): " + str(wordCount("Hello World")))
println("  wordCount('One Two Three'): " + str(wordCount("One Two Three")))

# Test 12.2: Title case (capitalize first letter of each word)
fn toTitleCase(str) {
    let result = ""
    let newWord = true
    for (let ch of str) {
        if (ch == " ") {
            result = result + ch
            newWord = true
        } else {
            if (newWord && ch >= "a" && ch <= "z") {
                # Convert to uppercase (simplified)
                let offset = 0
                for (let c = "a"; c <= ch; c = str(len(c) + 1)) {
                    offset = offset + 1
                }
                # This is simplified; real implementation would need char code conversion
                result = result + ch  # Keeping original for now
            } else {
                result = result + ch
            }
            newWord = false
        }
    }
    return result
}

println("✓ Test 12.2: Title case (simplified): " + toTitleCase("hello world"))

# Test 12.3: String to array of characters
fn toCharArray(str) {
    let arr = []
    let idx = 0
    for (let ch of str) {
        arr[idx] = ch
        idx = idx + 1
    }
    return arr
}

let charArr = toCharArray("ABC")
print("✓ Test 12.3: Character array: ")
for (let c of charArr) {
    print(c + " ")
}
println()

# Test 12.4: Join array to string
fn join(arr, separator) {
    let result = ""
    let first = true
    for (let item of arr) {
        if (!first) {
            result = result + separator
        }
        result = result + str(item)
        first = false
    }
    return result
}

println("✓ Test 12.4: join(['a','b','c'], '-') = " + join(["a", "b", "c"], "-"))

# Test 12.5: Palindrome check
fn isPalindrome(str) {
    let left = 0
    let right = len(str) - 1
    while (left < right) {
        if (str[left] != str[right]) {
            return false
        }
        left = left + 1
        right = right - 1
    }
    return true
}

println("✓ Test 12.5: isPalindrome('racecar'): " + str(isPalindrome("racecar")))
println("  isPalindrome('hello'): " + str(isPalindrome("hello")))

println()

