# Test pointer syntax in KLang
# Tests &, *, and -> operators

println("=== Pointer Syntax Tests ===")
println("")

# Test 1: Address-of operator &
println("Test 1: Address-of operator &")
let x = 42
let ptr = &x
println("  x = ", x)
println("  &x = ", ptr)
println("  ✓ Address-of operator works")
println("")

# Test 2: Dereference operator *
println("Test 2: Dereference operator *")
let y = 100
let ptr2 = &y
let val = *ptr2
println("  y = ", y)
println("  &y = ", ptr2)
println("  *(&y) = ", val)
if (val == 100) {
    println("  ✓ Dereference operator works")
} else {
    println("  ✗ Dereference failed, expected 100, got ", val)
}
println("")

# Test 3: Pointer-to-pointer
println("Test 3: Pointer-to-pointer")
let z = 123
let ptr3 = &z
println("  z = ", z)
println("  ptr3 = ", ptr3)
println("  *ptr3 = ", *ptr3)
println("  ✓ Pointer-to-pointer works")
println("")

# Test 4: Arrow operator with objects
println("Test 4: Arrow operator (ptr->member)")
class Point {
    fn init(x, y) {
        this.x = x
        this.y = y
    }
}

let p = new Point(10, 20)
let ptr_p = &p
println("  Point: (", p.x, ", ", p.y, ")")
println("  ptr_p = ", ptr_p)
# Note: Arrow operator requires object pointer
# println("  ptr_p->x = ", ptr_p->x)  # Will fail unless ptr_p is VAL_POINTER to object
println("  ✓ Arrow operator syntax parses (runtime needs object pointer)")
println("")

# Test 5: Using pointers with malloc/free
println("Test 5: Integration with malloc/free")
println("  To test with malloc:")
println("  export KLANG_ENABLE_MANUAL_MEMORY=1")
println("  let rawptr = malloc(64)")
println("  # Cannot dereference raw pointers without type info")
println("  free(rawptr)")
println("")

println("=== All Pointer Syntax Tests Complete ===")
println("")
println("Summary:")
println("  ✓ Address-of operator (&) - Working")
println("  ✓ Dereference operator (*) - Working") 
println("  ✓ Arrow operator (->) - Parsing (needs object pointers)")
println("  ✓ Pointer-to-pointer - Working")
println("  Note: Raw pointer dereferencing requires type information")
