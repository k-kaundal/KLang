# ============================================
# Section 2: Property Access
# ============================================
println("Section 2: Property Access")
println("-" * 40)

# Test 2.1: Dot notation access
let user = {name: "Bob", age: 25, city: "NYC"}
println("✓ Test 2.1: user.name = " + user.name)
println("  user.age = " + str(user.age))
println("  user.city = " + user.city)

# Test 2.2: Access nested properties
let nested = {
    person: {
        name: "Charlie",
        address: {
            city: "Boston",
            zip: "02101"
        }
    }
}
println("✓ Test 2.2: nested.person.name = " + nested.person.name)
println("  nested.person.address.city = " + nested.person.address.city)

# Test 2.3: Access array in object
let withList = {numbers: [1, 2, 3, 4, 5]}
println("✓ Test 2.3: First number = " + str(withList.numbers[0]))

println()

# ============================================
# Section 3: Property Modification
# ============================================
println("Section 3: Property Modification")
println("-" * 40)

# Test 3.1: Modify existing property
let modifiable = {value: 10}
modifiable.value = 20
println("✓ Test 3.1: After modification: " + str(modifiable.value))

# Test 3.2: Add new property
let extendable = {a: 1}
extendable.b = 2
extendable.c = 3
println("✓ Test 3.2: Added properties b and c")

# Test 3.3: Modify nested property
let nestedMod = {data: {x: 10, y: 20}}
nestedMod.data.x = 100
println("✓ Test 3.3: Modified nested.data.x = " + str(nestedMod.data.x))

println()

# ============================================
# Section 4: Objects with Methods
# ============================================
println("Section 4: Objects with Methods")
println("-" * 40)

# Test 4.1: Object with method
let calculator = {
    value: 0,
    add: fn(x) {
        return calculator.value + x
    },
    set: fn(x) {
        calculator.value = x
    }
}
calculator.set(10)
println("✓ Test 4.1: calculator.add(5) = " + str(calculator.add(5)))

# Test 4.2: Counter object
let counter = {
    count: 0,
    increment: fn() {
        counter.count = counter.count + 1
        return counter.count
    },
    decrement: fn() {
        counter.count = counter.count - 1
        return counter.count
    },
    reset: fn() {
        counter.count = 0
    }
}
counter.increment()
counter.increment()
println("✓ Test 4.2: After 2 increments: " + str(counter.count))
counter.decrement()
println("  After 1 decrement: " + str(counter.count))

println()

# ============================================
# Section 5: Object Patterns
# ============================================
println("Section 5: Object Patterns")
println("-" * 40)

# Test 5.1: Configuration object
let config = {
    debug: true,
    timeout: 5000,
    apiUrl: "https://api.example.com",
    retries: 3
}
println("✓ Test 5.1: config.debug = " + str(config.debug))
println("  config.timeout = " + str(config.timeout))

# Test 5.2: Point object
let point = {
    x: 10,
    y: 20,
    distance: fn(other) {
        let dx = point.x - other.x
        let dy = point.y - other.y
        return (dx * dx + dy * dy) ** 0.5
    }
}
let point2 = {x: 13, y: 24}
println("✓ Test 5.2: Distance between points = " + str(point.distance(point2)))

# Test 5.3: Rectangle object
let rectangle = {
    width: 10,
    height: 5,
    area: fn() {
        return rectangle.width * rectangle.height
    },
    perimeter: fn() {
        return 2 * (rectangle.width + rectangle.height)
    }
}
println("✓ Test 5.3: Rectangle area = " + str(rectangle.area()))
println("  Rectangle perimeter = " + str(rectangle.perimeter()))

println()

# ============================================
# Section 6: Object Factory Functions
# ============================================
println("Section 6: Object Factory Functions")
println("-" * 40)

# Test 6.1: Create person factory
fn createPerson(name, age) {
    return {
        name: name,
        age: age,
        greet: fn() {
            return "Hello, I'm " + name + " and I'm " + str(age)
        }
    }
}

let alice = createPerson("Alice", 30)
let bob = createPerson("Bob", 25)
println("✓ Test 6.1: " + alice.greet())
println("  " + bob.greet())

# Test 6.2: Create counter factory
fn createCounter(initial) {
    return {
        value: initial,
        inc: fn() {
            createCounter.value = createCounter.value + 1
        },
        get: fn() {
            return createCounter.value
        }
    }
}

let counter1 = createCounter(0)
let counter2 = createCounter(100)
println("✓ Test 6.2: counter1.value = " + str(counter1.value))
println("  counter2.value = " + str(counter2.value))

println()

# ============================================
# Section 7: Object Composition
# ============================================
println("Section 7: Object Composition")
println("-" * 40)

# Test 7.1: Nested objects
let company = {
    name: "TechCorp",
    ceo: {
        name: "John Doe",
        age: 45
    },
    employees: [
        {name: "Alice", role: "Developer"},
        {name: "Bob", role: "Designer"}
    ]
}
println("✓ Test 7.1: company.name = " + company.name)
println("  CEO: " + company.ceo.name)
println("  First employee: " + company.employees[0].name)

# Test 7.2: Object with arrays and nested objects
let data = {
    users: [
        {id: 1, name: "User1"},
        {id: 2, name: "User2"}
    ],
    meta: {
        total: 2,
        page: 1
    }
}
println("✓ Test 7.2: Total users = " + str(data.meta.total))
println("  First user = " + data.users[0].name)

println()

