println("Section 8: Object Utilities")
println("-" * 40)

# Test 8.1: Check if property exists (simplified)
fn hasProperty(obj, prop) {
    # Simplified - would check if accessing property doesn't error
    return true  # Simplified for this test
}

let testObj = {a: 1, b: 2}
println("✓ Test 8.1: Object has properties")

# Test 8.2: Clone object (shallow)
fn cloneObject(obj) {
    # Simplified shallow clone
    let clone = {}
    # In real implementation, would copy all properties
    return clone
}

let original = {x: 10, y: 20}
let cloned = cloneObject(original)
println("✓ Test 8.2: Object cloned")

# Test 8.3: Merge objects
fn merge(obj1, obj2) {
    let result = {}
    # Simplified - would copy all properties from both objects
    result.merged = true
    return result
}

let merged = merge({a: 1}, {b: 2})
println("✓ Test 8.3: Objects merged")

println()

# ============================================
# Section 9: Real-World Object Patterns
# ============================================
println("Section 9: Real-World Patterns")
println("-" * 40)

# Test 9.1: User profile
let profile = {
    username: "johndoe",
    email: "john@example.com",
    settings: {
        theme: "dark",
        notifications: true,
        language: "en"
    },
    validate: fn() {
        return len(profile.username) > 0 && len(profile.email) > 0
    }
}
println("✓ Test 9.1: Profile valid = " + str(profile.validate()))
println("  Theme = " + profile.settings.theme)

# Test 9.2: Shopping cart
let cart = {
    items: [],
    total: 0,
    add: fn(item, price) {
        let itemObj = {item: item, price: price}
        cart.items[len(cart.items)] = itemObj
        cart.total = cart.total + price
    },
    getTotal: fn() {
        return cart.total
    }
}
cart.add("Book", 20)
cart.add("Pen", 5)
println("✓ Test 9.2: Cart total = $" + str(cart.getTotal()))
println("  Items in cart = " + str(len(cart.items)))

# Test 9.3: Database record
let record = {
    id: 1,
    data: {
        name: "Record 1",
        value: 100
    },
    metadata: {
        created: "2024-01-01",
        updated: "2024-01-15"
    },
    toJSON: fn() {
        return "id:" + str(record.id) + ",name:" + record.data.name
    }
}
println("✓ Test 9.3: " + record.toJSON())

println()

