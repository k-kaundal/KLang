# Test 11.3: Multiple returns (first wins)
fn multipleReturns(x) {
    if (x > 0) {
        return "positive"
    }
    return "non-positive"
}
println("✓ Test 11.3: multipleReturns(5) = " + multipleReturns(5))
println("  multipleReturns(-3) = " + multipleReturns(-3))

# Test 11.4: Deep recursion (careful with stack)
fn deepRecursion(n) {
    if (n <= 0) {
        return 0
    }
    return deepRecursion(n - 1)
}
deepRecursion(100)
println("✓ Test 11.4: Deep recursion (100 levels) completed")

println()

