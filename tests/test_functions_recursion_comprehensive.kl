println("✓ Test 1.4: add(10, 20) = " + str(result3))

# Test 1.5: Function with three parameters
fn volume(length, width, height) {
    return length * width * height
}
let result4 = volume(2, 3, 4)
println("✓ Test 1.5: volume(2, 3, 4) = " + str(result4))

