# ============================================
# Section 5: Recursive Functions
# ============================================
println("Section 5: Recursive Functions")
println("-" * 40)

# Test 5.1: Factorial
fn factorial(n) {
    if (n <= 1) {
        return 1
    }
    return n * factorial(n - 1)
}
println("✓ Test 5.1: factorial(5) = " + str(factorial(5)))
println("  factorial(0) = " + str(factorial(0)))
println("  factorial(6) = " + str(factorial(6)))

# Test 5.2: Fibonacci
fn fibonacci(n) {
    if (n <= 1) {
        return n
    }
    return fibonacci(n - 1) + fibonacci(n - 2)
}
println("✓ Test 5.2: fibonacci(10) = " + str(fibonacci(10)))
println("  fibonacci(7) = " + str(fibonacci(7)))

# Test 5.3: Sum of digits
fn sumDigits(n) {
    if (n < 10) {
        return n
    }
    return (n % 10) + sumDigits(n / 10)
}
println("✓ Test 5.3: sumDigits(12345) = " + str(sumDigits(12345)))

# Test 5.4: Power function (recursive)
fn powerRec(base, exp) {
    if (exp == 0) {
        return 1
    }
    if (exp == 1) {
        return base
    }
    return base * powerRec(base, exp - 1)
}
println("✓ Test 5.4: powerRec(2, 8) = " + str(powerRec(2, 8)))

# Test 5.5: GCD (Greatest Common Divisor)
fn gcd(a, b) {
    if (b == 0) {
        return a
    }
    return gcd(b, a % b)
}
println("✓ Test 5.5: gcd(48, 18) = " + str(gcd(48, 18)))

# Test 5.6: Countdown
fn countdown(n) {
    if (n <= 0) {
        println("Blast off!")
        return
    }
    println("  " + str(n) + "...")
    countdown(n - 1)
}
println("✓ Test 5.6: Countdown from 3:")
countdown(3)

println()

# ============================================
# Section 6: Mutual Recursion
# ============================================
println("Section 6: Mutual Recursion")
println("-" * 40)

# Test 6.1: Even/Odd check (mutual recursion)
fn isEven(n) {
    if (n == 0) {
        return true
    }
    return isOdd(n - 1)
}

fn isOdd(n) {
    if (n == 0) {
        return false
    }
    return isEven(n - 1)
}

println("✓ Test 6.1: isEven(4) = " + str(isEven(4)))
println("  isEven(7) = " + str(isEven(7)))
println("  isOdd(5) = " + str(isOdd(5)))
println("  isOdd(8) = " + str(isOdd(8)))

println()

# ============================================
# Section 7: Higher-Order Functions
# ============================================
println("Section 7: Higher-Order Functions")
println("-" * 40)

# Test 7.1: Function that takes function as parameter
fn applyOperation(x, y, operation) {
    return operation(x, y)
}

fn addOp(a, b) {
    return a + b
}

fn multiplyOp(a, b) {
    return a * b
}

let r1 = applyOperation(5, 3, addOp)
let r2 = applyOperation(5, 3, multiplyOp)
println("✓ Test 7.1: apply(5, 3, add) = " + str(r1))
println("  apply(5, 3, mult) = " + str(r2))

# Test 7.2: Function that returns a function
fn makeMultiplier(factor) {
    fn multiplier(x) {
        return x * factor
    }
    return multiplier
}

let times3 = makeMultiplier(3)
let times5 = makeMultiplier(5)
println("✓ Test 7.2: times3(10) = " + str(times3(10)))
println("  times5(10) = " + str(times5(10)))

# Test 7.3: Function composition
fn compose(f, g) {
    fn composed(x) {
        return f(g(x))
    }
    return composed
}

fn addOne(x) {
    return x + 1
}

fn timesTwo(x) {
    return x * 2
}

let addThenDouble = compose(timesTwo, addOne)
println("✓ Test 7.3: compose((x+1)*2)(5) = " + str(addThenDouble(5)))

println()

# ============================================
# Section 8: Closures
# ============================================
println("Section 8: Closures")
println("-" * 40)

# Test 8.1: Basic closure
fn makeCounter() {
    let count = 0
    fn counter() {
        count = count + 1
        return count
    }
    return counter
}

let counter1 = makeCounter()
println("✓ Test 8.1: counter() = " + str(counter1()))
println("  counter() = " + str(counter1()))
println("  counter() = " + str(counter1()))

# Test 8.2: Closure with parameter
fn makeAdder(x) {
    fn adder(y) {
        return x + y
    }
    return adder
}

let add10 = makeAdder(10)
let add20 = makeAdder(20)
println("✓ Test 8.2: add10(5) = " + str(add10(5)))
println("  add20(5) = " + str(add20(5)))

# Test 8.3: Closure capturing multiple variables
fn makePerson(name, age) {
    fn introduce() {
        return "Hi, I'm " + name + " and I'm " + str(age)
    }
    return introduce
}

let alice = makePerson("Alice", 30)
let bob = makePerson("Bob", 25)
println("✓ Test 8.3: " + alice())
println("  " + bob())

println()

