# Section 9: Function Scope and Variables
# ============================================
println("Section 9: Function Scope")
println("-" * 40)

# Test 9.1: Local variables don't leak
fn scopeTest() {
    let local = 100
    return local
}
let scopeResult = scopeTest()
println("✓ Test 9.1: Local variable: " + str(scopeResult))

# Test 9.2: Access global from function
let globalVar = 42
fn accessGlobal() {
    return globalVar * 2
}
println("✓ Test 9.2: Access global: " + str(accessGlobal()))

# Test 9.3: Modify global from function
let modifyMe = 10
fn modifyGlobal() {
    modifyMe = 20
}
modifyGlobal()
println("✓ Test 9.3: Modified global: " + str(modifyMe))

# Test 9.4: Nested function scope
fn outer() {
    let outerVar = "outer"
    fn inner() {
        let innerVar = "inner"
        return outerVar + " " + innerVar
    }
    return inner()
}
println("✓ Test 9.4: Nested scope: " + outer())

println()

# ============================================
# Section 10: Complex Function Patterns
# ============================================
println("Section 10: Complex Patterns")
println("-" * 40)

# Test 10.1: Array sum (recursive)
fn sumArray(arr, index = 0) {
    if (index >= len(arr)) {
        return 0
    }
    return arr[index] + sumArray(arr, index + 1)
}
let numbers = [1, 2, 3, 4, 5]
println("✓ Test 10.1: sumArray([1,2,3,4,5]) = " + str(sumArray(numbers)))

# Test 10.2: Find max in array (recursive)
fn findMax(arr, index = 0, currentMax = null) {
    if (index >= len(arr)) {
        return currentMax
    }
    if (currentMax == null || arr[index] > currentMax) {
        currentMax = arr[index]
    }
    return findMax(arr, index + 1, currentMax)
}
let maxArr = [23, 5, 89, 12, 67, 3]
println("✓ Test 10.2: findMax([23,5,89,12,67,3]) = " + str(findMax(maxArr)))

# Test 10.3: String reversal (recursive)
fn reverseString(s, index = 0) {
    if (index >= len(s)) {
        return ""
    }
    return reverseString(s, index + 1) + s[index]
}
println("✓ Test 10.3: reverse('hello') = " + reverseString("hello"))

# Test 10.4: Palindrome checker (recursive)
fn isPalindrome(s, start = 0, end = -1) {
    if (end == -1) {
        end = len(s) - 1
    }
    if (start >= end) {
        return true
    }
    if (s[start] != s[end]) {
        return false
    }
    return isPalindrome(s, start + 1, end - 1)
}
println("✓ Test 10.4: isPalindrome('racecar') = " + str(isPalindrome("racecar")))
println("  isPalindrome('hello') = " + str(isPalindrome("hello")))

# Test 10.5: Binary search (recursive)
fn binarySearch(arr, target, left = 0, right = -1) {
    if (right == -1) {
        right = len(arr) - 1
    }
    if (left > right) {
        return -1
    }
    let mid = (left + right) / 2
    if (arr[mid] == target) {
        return mid
    }
    if (arr[mid] > target) {
        return binarySearch(arr, target, left, mid - 1)
    }
    return binarySearch(arr, target, mid + 1, right)
}
let sorted = [1, 3, 5, 7, 9, 11, 13, 15]
println("✓ Test 10.5: binarySearch for 7: index " + str(binarySearch(sorted, 7)))
println("  binarySearch for 15: index " + str(binarySearch(sorted, 15)))

println()

