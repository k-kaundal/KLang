# 9. Advanced Recursion - Tower of Hanoi
class TowerOfHanoi {
    fn solve(n: int, from: string, to: string, aux: string) {
        if n == 1 {
            println("Move disk 1 from " + from + " to " + to)
            return
        }
        
        this.solve(n - 1, from, aux, to)
        println("Move disk " + n + " from " + from + " to " + to)
        this.solve(n - 1, aux, to, from)
    }
}

println("\n=== Tower of Hanoi ===")
let toh = new TowerOfHanoi()
toh.solve(3, "A", "C", "B")

