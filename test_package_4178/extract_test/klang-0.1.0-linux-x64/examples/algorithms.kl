# Advanced algorithms in KLang

# 1. Binary Search
class BinarySearch {
    fn search(arr, target: int) -> int {
        let left = 0
        let right = len(arr) - 1
        
        while left <= right {
            let mid = (left + right) / 2
            let mid_val = arr[mid]
            
            if mid_val == target {
                println("Found at index: " + mid)
                return mid
            } else if mid_val < target {
                left = mid + 1
            } else {
                right = mid - 1
            }
        }
        
        println("Not found")
        return -1
    }
}

println("=== Binary Search ===")
let bs = new BinarySearch()
let sorted_arr = [1, 3, 5, 7, 9, 11, 13, 15]
bs.search(sorted_arr, 7)
bs.search(sorted_arr, 10)

# 2. Recursive Fibonacci with Memoization
class FibonacciMemo {
    let cache = []
    
    fn init() {
        this.cache = []
    }
    
    fn calculate(n: int) -> int {
        if n <= 1 {
            return n
        }
        
        # In full implementation, would check cache here
        let result = this.calculate(n - 1) + this.calculate(n - 2)
        return result
    }
}

println("\n=== Fibonacci with Memoization ===")
let fib = new FibonacciMemo()
println("fib(10) = " + fib.calculate(10))

