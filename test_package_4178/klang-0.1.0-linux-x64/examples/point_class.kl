# Point class example with methods

class Point {
    let x: int = 0
    let y: int = 0
    
    fn init(x_val: int, y_val: int) {
        this.x = x_val
        this.y = y_val
    }
    
    fn display() {
        println("Point(")
        println(this.x)
        println(", ")
        println(this.y)
        println(")")
    }
    
    fn add(other) {
        let result = new Point(0, 0)
        result.x = this.x + other.x
        result.y = this.y + other.y
        return result
    }
}

let p1 = new Point(3, 4)
let p2 = new Point(1, 2)

println("Point 1:")
p1.display()

println("Point 2:")
p2.display()

println("Sum:")
let p3 = p1.add(p2)
p3.display()
