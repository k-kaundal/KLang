# Network utilities
fn isValidIP(ip) {
    # Simple IPv4 validation
    let parts = ip.split(".")
    
    if len(parts) != 4 {
        return false
    }
    
    for part in parts {
        let num = int(part)
        if num < 0 || num > 255 {
            return false
        }
    }
    
    return true
}

fn isValidPort(port) {
    let num = int(port)
    return num >= 1 && num <= 65535
}

# Helper: HTTP request (would call native implementation)
