let ICON_ARROW_RIGHT = "→"
let ICON_ARROW_LEFT = "←"
let ICON_ARROW_UP = "↑"
let ICON_ARROW_DOWN = "↓"
let ICON_STAR = "★"
let ICON_HEART = "♥"
let ICON_WARNING = "⚠"
let ICON_INFO = "ℹ"
let ICON_QUESTION = "?"
let ICON_BULLET = "•"
let ICON_CIRCLE = "○"
let ICON_FILLED_CIRCLE = "●"
let ICON_SQUARE = "□"
let ICON_FILLED_SQUARE = "■"
