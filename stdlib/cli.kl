# ============================================
# KLang CLI Library
# ============================================
# Beautiful command-line interface utilities
# 100% Pure KLang implementation
#
# Features:
# - Colors and text formatting
# - Box drawing and borders
# - Progress bars and spinners
# - Tables and menus
# - Interactive prompts
# - Icons and symbols

# ===========================================
# ANSI Color Codes
# ===========================================

# Text colors
let BLACK = "\x1b[30m"
let RED = "\x1b[31m"
let GREEN = "\x1b[32m"
let YELLOW = "\x1b[33m"
let BLUE = "\x1b[34m"
let MAGENTA = "\x1b[35m"
let CYAN = "\x1b[36m"
let WHITE = "\x1b[37m"
let GRAY = "\x1b[90m"

# Bright colors
let BRIGHT_RED = "\x1b[91m"
let BRIGHT_GREEN = "\x1b[92m"
let BRIGHT_YELLOW = "\x1b[93m"
let BRIGHT_BLUE = "\x1b[94m"
let BRIGHT_MAGENTA = "\x1b[95m"
let BRIGHT_CYAN = "\x1b[96m"
let BRIGHT_WHITE = "\x1b[97m"

# Background colors
let BG_BLACK = "\x1b[40m"
let BG_RED = "\x1b[41m"
let BG_GREEN = "\x1b[42m"
let BG_YELLOW = "\x1b[43m"
let BG_BLUE = "\x1b[44m"
let BG_MAGENTA = "\x1b[45m"
let BG_CYAN = "\x1b[46m"
let BG_WHITE = "\x1b[47m"

# Text styles
let BOLD = "\x1b[1m"
let DIM = "\x1b[2m"
let ITALIC = "\x1b[3m"
let UNDERLINE = "\x1b[4m"
let BLINK = "\x1b[5m"
let REVERSE = "\x1b[7m"
let HIDDEN = "\x1b[8m"
let STRIKETHROUGH = "\x1b[9m"

# Reset
let RESET = "\x1b[0m"

# ===========================================
# Box Drawing Characters
# ===========================================

# Single line box characters
let BOX_SINGLE_HORIZONTAL = "─"
let BOX_SINGLE_VERTICAL = "│"
let BOX_SINGLE_TOP_LEFT = "┌"
let BOX_SINGLE_TOP_RIGHT = "┐"
let BOX_SINGLE_BOTTOM_LEFT = "└"
let BOX_SINGLE_BOTTOM_RIGHT = "┘"
let BOX_SINGLE_T_DOWN = "┬"
let BOX_SINGLE_T_UP = "┴"
let BOX_SINGLE_T_RIGHT = "├"
let BOX_SINGLE_T_LEFT = "┤"
let BOX_SINGLE_CROSS = "┼"

# Double line box characters
let BOX_DOUBLE_HORIZONTAL = "═"
let BOX_DOUBLE_VERTICAL = "║"
let BOX_DOUBLE_TOP_LEFT = "╔"
let BOX_DOUBLE_TOP_RIGHT = "╗"
let BOX_DOUBLE_BOTTOM_LEFT = "╚"
let BOX_DOUBLE_BOTTOM_RIGHT = "╝"
let BOX_DOUBLE_T_DOWN = "╦"
let BOX_DOUBLE_T_UP = "╩"
let BOX_DOUBLE_T_RIGHT = "╠"
let BOX_DOUBLE_T_LEFT = "╣"
let BOX_DOUBLE_CROSS = "╬"

# Round box characters
let BOX_ROUND_TOP_LEFT = "╭"
let BOX_ROUND_TOP_RIGHT = "╮"
let BOX_ROUND_BOTTOM_LEFT = "╰"
let BOX_ROUND_BOTTOM_RIGHT = "╯"

# ===========================================
# Icons and Symbols
